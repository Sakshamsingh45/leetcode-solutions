emp=temp.next\\n        ans=c1+c2\\n        head=cur=ListNode(0)\\n        for i in str(ans):\\n            cur.next=ListNode(int(i))\\n            cur=cur.next\\n\\n        return head.next\\n\\n        ","compare_result":"","title_slug":"add-two-numbers-ii","has_notes":false,"flag_type":1,"frontend_id":431},{"id":1998389714,"question_id":234,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0month, 2\xc2\xa0weeks","timestamp":1778268733,"status":10,"status_display":"Accepted","runtime":"99 ms","url":"/submissions/detail/1998389714/","is_pending":"Not Pending","title":"Palindrome Linked List","memory":"54.1 MB","code":"# Definition for singly-linked list.\\n# class ListNode:\\n#     def __init__(self, val=0, next=None):\\n#         self.val = val\\n#         self.next = next\\nclass Solution:\\n    def isPalindrome(self, head: Optional[ListNode]) -> bool:\\n        cur=head\\n        s=\\"\\"\\n        while cur!=None:\\n            s+=str(cur.val)\\n            cur=cur.next\\n        return s==s[::-1]\\n","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"palindrome-linked-list","has_notes":false,"flag_type":1,"frontend_id":430},{"id":1997886252,"question_id":66,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0month, 2\xc2\xa0weeks","timestamp":1778218605,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1997886252/","is_pending":"Not Pending","title":"Plus One","memory":"19.4 MB","code":"class Solution:\\n    def plusOne(self, digits: List[int]) -> List[int]:\\n        carry=1\\n        for i in range(-1,-len(digits)-1,-1):\\n            s=digits[i]+carry\\n            carry=0 if s<10 else 1\\n            d=s%10\\n            digits[i]=d\\n        if carry:\\n            digits.insert(0,carry)\\n        return digits","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111