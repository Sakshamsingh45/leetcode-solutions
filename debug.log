stack.append(ch)\\n            return \'\'.join(stack), total\\n\\n        total_score = 0\\n\\n        # Always remove higher-scoring pattern first\\n        if x > y:\\n            s, gain1 = remove_pattern(s, \'a\', \'b\', x)\\n            s, gain2 = remove_pattern(s, \'b\', \'a\', y)\\n        else:\\n            s, gain1 = remove_pattern(s, \'b\', \'a\', y)\\n            s, gain2 = remove_pattern(s, \'a\', \'b\', x)\\n\\n        total_score = gain1 + gain2\\n        return total_score\\n","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-score-from-removing-substrings","has_notes":false,"flag_type":1,"frontend_id":179}],"has_next":true,"last_key":""}'
