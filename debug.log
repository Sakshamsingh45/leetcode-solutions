","memory":"21.1 MB","code":"class Solution:\\n    def majorityElement(self, nums: List[int]) -> int:\\n        hash = {}\\n        res = majority = 0\\n        \\n        for n in nums:\\n            hash[n] = 1 + hash.get(n, 0)\\n            if hash[n] > majority:\\n                res = n\\n                majority = hash[n]\\n        \\n        return res","compare_result":"11111111111111111111111111111111111111111111111111111","title_slug":"majority-element","has_notes":false,"flag_type":1,"frontend_id":387},{"id":1951295969,"question_id":53,"lang":"python3","lang_name":"Python3","time":"3\xc2\xa0months, 1\xc2\xa0week","timestamp":1773765133,"status":10,"status_display":"Accepted","runtime":"23 ms","url":"/submissions/detail/1951295969/","is_pending":"Not Pending","title":"Maximum Subarray","memory":"31.6 MB","code":"class Solution:\\n    def maxSubArray(self, nums: List[int]) -> int:\\n        maxs=float(\\"-inf\\")\\n        count=0\\n        for i in nums:\\n            count+=i\\n            if count<i:\\n                count=i\\n            if count>maxs:\\n                maxs=count\\n        return maxs\\n","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-subarray","has_notes":false,"flag_type":1,"frontend_id":386},{"id":1948927748,"question_id":118,"lang":"python3","lang_name":"Python3","time":"3\xc2\xa0months, 1\xc2\xa0week","timestamp":1773566148,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1948927748/","is_pending":"Not Pending","title":"Pascal\'s Triangle","memory":"19.1 MB","code":"class Solution:\\n    def generate(self, numRows: int) -> List[List[int]]:\\n        if numRows==1:\\n            return [[1]]\\n        elif numRows==2:\\n            return [[1],[1,1]]\\n        ans=[[1],[1,1]]\\n        for i in range(2,numRows):\\n            row=[1]\\n            prev=ans[i-1]\\n            for j in range(1,len(prev)):\\n                row.append(prev[j-1]+prev[j])\\n            row.append(1)\\n            ans.append(row)\\n        return ans\\n\\n","compare_result":"111111111111111111111111111111","title_slug":"pascals-triangle","has_notes":false,"flag_type":1,"frontend_id":385},{"id":1944675977,"question_id":1054,"lang":"python3","lang_name":"Python3","time":"3\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1773209490,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1944675977/","is_pending":"Not Pending","title":"Complement of Base 10 Integer","memory":"19.4 MB","code":"class Solution:\\n    def bitwiseComplement(self, n: int) -> int:\\n        n=bin(n)[2:]\\n        s=\\"\\".join(\\"1\\" if i==\\"0\\" else \\"0\\" for i in n)\\n        return int(s,2)","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"complement-of-base-10-integer","has_notes":false,"flag_type":1,"frontend_id":384},{"id":1940925071,"question_id":15,"lang":"python3","lang_name":"Python3","time":"3\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1772898231,"status":10,"status_display":"Accepted","runtime":"635 ms","url":"/submissions/detail/1940925071/","is_pending":"Not Pending","title":"3Sum","memory":"22.2 MB","code":"class Solution:\\n    def threeSum(self, nums: List[int]) -> List[List[int]]:\\n        nums.sort()\\n        n = len(nums)\\n        res = []\\n        \\n        for i in range(n):\\n            # Skip duplicate elements for i\\n            if i > 0 and nums[i] == nums[i - 1]:\\n                continue\\n            \\n            l, r = i + 1, n - 1\\n            while l < r:\\n                s = nums[i] + nums[l] + nums[r]\\n                \\n                if s == 0:\\n                    res.append([nums[i], nums[l], nums[r]])\\n                    l += 1\\n                    r -= 1\\n                    # Skip duplicates for l and r\\n                    while l < r and nums[l] == nums[l - 1]:\\n                        l += 1\\n                    while l < r and nums[r] == nums[r + 1]:\\n                        r -= 1\\n                elif s < 0:\\n                    l += 1\\n                else:\\n                    r -= 1\\n        \\n        return res\\n","compare_result":"","title_slug":"3sum","has_notes":false,"flag_type":1,"frontend_id":383},{"id":1940911762,"question_id":2017,"lang":"python3","lang_name":"Python3","time":"3\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1772897280,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1940911762/","is_pending":"Not Pending","title":"Minimum Number of Flips to Make the Binary String Alternating","memory":"N/A","code":"class Solution:\\n    def minFlips(self, s: str) -> int:\\n        if \\"00\\" not in s and \\"11\\" not in s:\\n            return 0\\n        s=list(s)\\n        while s[-1]!=s[0] :\\n            a=s[0]\\n            s.pop(0)\\n            s.append(a)\\n        s0,s1=0,0\\n        for i in range(len(s)):\\n            if i%2==0:\\n                if s[i]==\\"1\\":\\n                    s1+=1\\n                else:\\n                    s0+=1\\n            else:\\n                if s[i]==\\"0\\":\\n                    s1+=1\\n                else:\\n                    s0+=1\\n        return min(s0,s1)","compare_result":"11111011111000110001011000100110111001100111000001010010111111111","title_slug":"minimum-number-of-flips-to-make-the-binary-string-alternating","has_notes":false,"flag_type":1,"frontend_id":382},{"id":1939383810,"question_id":1910,"lang":"python3","lang_name":"Python3","time":"3\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1772771981,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1939383810/","is_pending":"Not Pending","title":"Check if Binar