or (int i = triangle.size() - 2; i >= 0; i--)\\n            for (int j = 0; j < triangle[i].size(); j++)\\n                triangle[i][j] +=\\n                    min(triangle[i + 1][j], triangle[i + 1][j + 1]);\\n\\n        return triangle[0][0];\\n    }\\n};","compare_result":"0000000000000000000000000000000000000000000000","title_slug":"triangle","has_notes":false,"flag_type":1,"frontend_id":221},{"id":1781969213,"question_id":120,"lang":"python3","lang_name":"Python3","time":"9\xc2\xa0months","timestamp":1758778927,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1781969213/","is_pending":"Not Pending","title":"Triangle","memory":"N/A","code":"class Solution:\\n    def minimumTotal(self, triangle: List[List[int]]) -> int:\\n        min1=0\\n        for i in triangle :\\n            min1+=min(i)\\n        return min1","compare_result":"1111011000000001100001000011000001010000000100","title_slug":"triangle","has_notes":false,"flag_type":1,"frontend_id":220},{"id":1781630000,"question_id":166,"lang":"python3","lang_name":"Python3","time":"9\xc2\xa0months","timestamp":1758742537,"status":10,"status_display":"Accepted","runtime":"3 ms","url":"/submissions/detail/1781630000/","is_pending":"Not Pending","title":"Fraction to Recurring Decimal","memory":"18 MB","code":"class Solution:\\n    def fractionToDecimal(self, numerator: int, denominator: int) -> str:\\n        if numerator==0: return \'0\'\\n        ans=[]\\n        if (numerator<0)^(denominator<0): ans.append(\'-\')\\n        num=abs(numerator)\\n        den=abs(denominator)\\n\\n        q, r=divmod(num, den)\\n        ans.append(str(q))\\n\\n        if r==0: return \\"\\".join(ans)\\n        ans.append(\'.\')\\n        mp={}\\n        frac=[]\\n        \\n        i=0\\n        while r!=0:\\n            if r in mp:\\n                frac.insert(mp[r], \'(\')\\n                frac.append(\')\')\\n                break\\n            mp[r]=i\\n            r*=10\\n            frac.append(str(r//den))\\n            r%=den\\n            i+=1\\n        return \\"\\".join(ans+frac)","compare_result":"11111111111111111111111111111111111111111","title_slug":"fraction-to-recurring-decimal","has_notes":false,"flag_type":1,"frontend_id":219}],"has_next":true,"last_key":""}'
