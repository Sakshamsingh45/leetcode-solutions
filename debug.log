2026-06-26 14:34:17,833 [DEBUG] leetcode.py:152 - b'{"submissions_dump":[{"id":1707957767,"question_id":1818,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months","timestamp":1753242076,"status":10,"status_display":"Accepted","runtime":"6164 ms","url":"/submissions/detail/1707957767/","is_pending":"Not Pending","title":"Maximum Score From Removing Substrings","memory":"19.4 MB","code":"class Solution:\\n    def maximumGain(self, s: str, x: int, y: int) -> int:\\n        score = 0\\n        i = 0\\n        s = list(s)\\n        if x > y:\\n            a, b = \\"ab\\", \\"ba\\"\\n            a_score, b_score = x, y\\n        else:\\n            a, b = \\"ba\\", \\"ab\\"\\n            a_score, b_score = y, x\\n\\n        i = 0\\n        while i < len(s) - 1:\\n            if s[i] + s[i+1] == a:\\n                score += a_score\\n                s.pop(i)\\n                s.pop(i)\\n                i = max(i - 2, -1)\\n            i += 1\\n\\n        j = 0\\n        while j < len(s) - 1:\\n            if s[j] + s[j+1] == b:\\n                score += b_score\\n                s.pop(j)\\n                s.pop(j)\\n                j = max(j - 2, -1)\\n            j += 1\\n\\n        return score\\n","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-score-from-removing-substrings","has_notes":false,"flag_type":1,"frontend_id":178},{"id":1707692887,"question_id":1813,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months","timestamp":1753211663,"status":10,"status_display":"Accepted","runtime":"892 ms","url":"/submissions/detail/1707692887/","is_pending":"Not Pending","title":"Maximum Erasure Value","memory":"29.4 MB","code":"class Solution:\\n    def maximumUniqueSubarray(self, nums: List[int]) -> int:\\n        current_sum = 0\\n        max_sum = 0\\n        a = []\\n\\n        for i in nums:\\n            if i not in a:\\n                a.append(i)\\n                current_sum += i\\n            else:\\n                index = a.index(i)\\n                z=0\\n                while z < index + 1:\\n                    removed = a.pop(0)\\n                    current_sum -= removed\\n                    z+=1\\n                a.append(i)\\n                current_sum += i\\n\\n            max_sum = max(max_sum, current_sum)\\n\\n        return max_sum\\n","compare_result":"11111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-erasure-value","has_notes":false,"flag_type":1,"frontend_id":177},{"id":1707687776,"question_id":1813,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months","timestamp":1753211344,"status":10,"status_display":"Accepted","runtime":"896 ms","url":"/submissions/detail/1707687776/","is_pending":"Not Pending","title":"Maximum Erasure Value","memory":"29.5 MB","code":"class Solution:\\n    def maximumUniqueSubarray(self, nums: List[int]) -> int:\\n        current_sum = 0\\n        max_sum = 0\\n        a = []\\n\\n        for i in nums:\\n            if i not in a:\\n                a.append(i)\\n                current_sum += i\\n            else:\\n                index = a.index(i)\\n                # Remove elements before and including duplicate\\n                for _ in range(index + 1):\\n                    removed = a.pop(0)\\n                    current_sum -= removed\\n                # Now add the current element\\n                a.append(i)\\n                current_sum += i\\n\\n            max_sum = max(max_sum, current_sum)\\n\\n        return max_sum\\n","compare_result":"11111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-erasure-value","has_notes":false,"flag_type":1,"frontend_id":176},{"id":1707669823,"question_id":1813,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months","timestamp":1753210265,"status":10,"status_display":"Accepted","runtime":"189 ms","url":"/submissions/detail/1707669823/","is_pending":"Not Pending","title":"Maximum Erasure Value","memory":"29 MB","code":"class Solution:\\n    def maximumUniqueSubarray(self, nums: List[int]) -> int:\\n        seen = set()\\n        left = 0\\n        current_sum = 0\\n        max_sum = 0\\n\\n        for right in range(len(nums)):\\n            while nums[right] in seen:\\n                seen.remove(nums[left])\\n                current_sum -= nums[left]\\n                left += 1\\n            seen.add(nums[right])\\n            current_sum += nums[right]\\n            max_sum = max(max_sum, current_sum)\\n\\n        return max_sum\\n","compare_result":"11111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-erasure-value","has_notes":false,"flag_type":1,"frontend_id":175},{"id":1707620000,"question_id":1813,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months","timestamp":1753207826,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1707620000/","is_pending":"Not Pending","title":"Maximum Erasure Value","memory":"N/A","code":"class Solution:\\n    def maximumUniqueSubarray(self, nums: List[int]) -> int:\\n        score = 0\\n        a=[]\\n        for i in range(len(nums)):\\n            if not a or nums[i] not in a:\\n                a.append(nums[i])\\n                score+=nums[i]\\n        return score\\n        ","compare_result":"11111111000000000000000000000000000000000000000000000000000000","title_slug":"maximum-erasure-value","has_notes":false,"flag_type":1,"frontend_id":174},{"id":1705631142,"question_id":1302,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months","timestamp":1753083152,"status":10,"status_display":"Accepted","runtime":"395 ms","url":"/submissions/detail/1705631142/","is_pending":"Not Pending","title":"Delete Characters to Make Fancy String","memory":"19.4 MB","code":"class Solution:\\n    def makeFancyString(self, s: str) -> str:\\n        ans=\\"\\"+s[0]\\n        count=0\\n        for i in range(1,len(s)):\\n            pev=s[i-1]\\n            if s[i]==pev:\\n                count+=1\\n\\n            elif s[i]!=pev or count>=2:\\n                count=0\\n            \\n\\n            if count<2:\\n                ans+=s[i]\\n        return ans","compare_result":"","title_slug":"delete-characters-to-make-fancy-string","has_notes":false,"flag_type":1,"frontend_id":173},{"id":1705624794,"question_id":1302,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months","timestamp":1753082741,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1705624794/","is_pending":"Not Pending","title":"Delete Characters to Make Fancy String","memory":"N/A","code":"class Solution:\\n    def makeFancyString(self, s: str) -> str:\\n        ans=\\"\\"+s[0]\\n        count=0\\n        for i in range(1,len(s)):\\n            pev=s[i-1]\\n            if s[i]==pev:\\n                count+=1\\n\\n            elif count>=2:\\n                count=0\\n\\n            if count<2:\\n                ans+=s[i]\\n        return ans","compare_result":"","title_slug":"delete-characters-to-make-fancy-string","has_notes":false,"flag_type":1,"frontend_id":172},{"id":1705005752,"question_id":2079,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months","timestamp":1753030892,"status":10,"status_display":"Accepted","runtime":"172 ms","url":"/submissions/detail/1705005752/","is_pending":"Not Pending","title":"Delete Duplicate Folders in System","memory":"48.9 MB","code":"class Trie:\\n    # current node structure\'s serialized representation\\n    serial: str = \\"\\"\\n    # current node\'s child nodes\\n    children: dict\\n\\n    def __init__(self):\\n        self.children = dict()\\n\\n\\nclass Solution:\\n    def deleteDuplicateFolder(self, paths: List[List[str]]) -> List[List[str]]:\\n        # root node\\n        root = Trie()\\n\\n        for path in paths:\\n            cur = root\\n            for node in path:\\n                if node not in cur.children:\\n                    cur.children[node] = Trie()\\n                cur = cur.children[node]\\n\\n        # hash table records the occurrence times of each serialized representation\\n        freq = Counter()\\n\\n        # post-order traversal based on depth-first search, calculate the serialized representation of each node structure\\n        def construct(node: Trie) -> None:\\n            # if it is a leaf node, then the serialization is represented as an empty string, and no operation is required.\\n            if not node.children:\\n                return\\n\\n            v = list()\\n            # if it is not a leaf node, the serialization representation of the child node structure needs to be calculated first.\\n            for folder, child in node.children.items():\\n                construct(child)\\n                v.append(folder + \\"(\\" + child.serial + \\")\\")\\n\\n            # to prevent issues with order, sorting is needed\\n            v.sort()\\n            node.serial = \\"\\".join(v)\\n            # add to hash table\\n            freq[node.serial] += 1\\n\\n        construct(root)\\n\\n        ans = list()\\n        # record the path from the root node to the current node.\\n        path = list()\\n\\n        def operate(node: Trie) -> None:\\n            # if the serialization appears more than once in the hash table, it needs to be deleted.\\n            if freq[node.serial] > 1:\\n                return\\n            # otherwise add the path to the answer\\n            if path:\\n                ans.append(path[:])\\n\\n            for folder, child in node.children.items():\\n                path.append(folder)\\n                operate(child)\\n                path.pop()\\n\\n        operate(root)\\n        return ans","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"delete-duplicate-folders-in-system","has_notes":false,"flag_type":1,"frontend_id":171},{"id":1700724411,"question_id":3491,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months, 1\xc2\xa0week","timestamp":1752718843,"status":10,"status_display":"Accepted","runtime":"1355 ms","url":"/submissions/detail/1700724411/","is_pending":"Not Pending","title":"Find the Maximum Length of Valid Subsequence II","memory":"25.9 MB","code":"class Solution:\\n    def maximumLength(self, nums: List[int], k: int) -> int:\\n        dp = [[0] * k for _ in range(k)]\\n        res = 0\\n        for num in nums:\\n            num %= k\\n            for prev in range(k):\\n                dp[prev][num] = dp[num][prev] + 1\\n                res = max(res, dp[prev][num])\\n        return res","compare_result":"","title_slug":"find-the-maximum-length-of-valid-subsequence-ii","has_notes":false,"flag_type":1,"frontend_id":170},{"id":1700192437,"question_id":3490,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months, 1\xc2\xa0week","timestamp":1752677714,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1700192437/","is_pending":"Not Pending","title":"Find the Maximum Length of Valid Subsequence I","memory":"N/A","code":"class Solution:\\n    def maximumLength(self, nums: List[int]) -> int:\\n        n = len(nums)\\n        max_len = 1\\n\\n        # Try for both parities: 0 and 1\\n        for parity in [0, 1]:\\n            length = 1\\n            prev = nums[0]\\n            for i in range(1, n):\\n                if (prev + nums[i]) % 2 == parity:\\n                    length += 1\\n                    prev = nums[i]\\n                # if not matching, skip nums[i] (don\'t update prev)\\n            if length > max_len:\\n                max_len = length\\n\\n        return max_len\\n","compare_result":"","title_slug":"find-the-maximum-length-of-valid-subsequence-i","has_notes":false,"flag_type":1,"frontend_id":169},{"id":1700191927,"question_id":3490,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months, 1\xc2\xa0week","timestamp":1752677686,"status":10,"status_display":"Accepted","runtime":"56 ms","url":"/submissions/detail/1700191927/","is_pending":"Not Pending","title":"Find the Maximum Length of Valid Subsequence I","memory":"39 MB","code":"class Solution:\\n    def maximumLength(self, nums: List[int]) -> int:\\n        n=len(nums)\\n        if n==2: return 2\\n        z=nums[0]&1\\n        Len=[1-z, z, 1]\\n        for xx in nums[1:]:\\n            x=xx&1\\n            Len[x&1]+=1\\n            if x!=z:\\n                Len[2]+=1\\n                z=1-z\\n        return max(Len)","compare_result":"","title_slug":"find-the-maximum-length-of-valid-subsequence-i","has_notes":false,"flag_type":1,"frontend_id":168},{"id":1698871454,"question_id":3396,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months, 1\xc2\xa0week","timestamp":1752588164,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1698871454/","is_pending":"Not Pending","title":"Valid Word","memory":"18 MB","code":"class Solution:\\n    def isValid(self, word: str) -> bool:\\n        if len(word) < 3:\\n            return False\\n        \\n        v = 0  # vowel count\\n        c = 0  # consonant count\\n\\n        for ch in word:\\n            if not ch.isalnum():  # not a letter or digit\\n                return False\\n\\n            if ch.isalpha():\\n                if ch.lower() in [\'a\', \'e\', \'i\', \'o\', \'u\']:\\n                    v += 1\\n                else:\\n                    c += 1\\n\\n        return v > 0 and c > 0\\n","compare_result":"","title_slug":"valid-word","has_notes":false,"flag_type":1,"frontend_id":167},{"id":1698864920,"question_id":3396,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months, 1\xc2\xa0week","timestamp":1752587817,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1698864920/","is_pending":"Not Pending","title":"Valid Word","memory":"N/A","code":"class Solution:\\n    def isValid(self, word: str) -> bool:\\n        v=0\\n        c=0\\n        d=0\\n        for i in word:\\n            if i.isalpha():\\n                if i.lower() in [\'a\', \'e\', \'i\', \'o\', \'u\']:\\n                    v+=1\\n                elif ord(i.lower())<ord(\\"z\\") and ord(i.lower())>ord(\\"a\\") :\\n                    c+=1\\n            if i.isdigit():\\n                d=1\\n        return True if d!=0 and v!=0 and c!=0 else False","compare_result":"","title_slug":"valid-word","has_notes":false,"flag_type":1,"frontend_id":166},{"id":1697775726,"question_id":1411,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months, 1\xc2\xa0week","timestamp":1752512034,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1697775726/","is_pending":"Not Pending","title":"Convert Binary Number in a Linked List to Integer","memory":"17.8 MB","code":"# Definition for singly-linked list.\\nclass ListNode:\\n    def __init__(self, val=0, next=None):\\n        self.val = val\\n        self.next = next\\n\\nclass Solution:\\n    def getDecimalValue(self, head: ListNode) -> int:\\n        result = 0\\n        while head:\\n            result = result * 2 + head.val\\n            head = head.next\\n        return result","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"convert-binary-number-in-a-linked-list-to-integer","has_notes":false,"flag_type":1,"frontend_id":165},{"id":1694553403,"question_id":2479,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1752257048,"status":10,"status_display":"Accepted","runtime":"743 ms","url":"/submissions/detail/1694553403/","is_pending":"Not Pending","title":"Meeting Rooms III","memory":"51.5 MB","code":"class Solution:\\n    def mostBooked(self, n: int, meetings: List[List[int]]) -> int:\\n        room_availability_time = [0] * n\\n        meeting_count = [0] * n\\n        for start, end in sorted(meetings):\\n            min_room_availability_time = inf\\n            min_available_time_room = 0\\n            found_unused_room = False\\n            for i in range(n):\\n                if room_availability_time[i] <= start:\\n                    found_unused_room = True\\n                    meeting_count[i] += 1\\n                    room_availability_time[i] = end\\n                    break\\n                if min_room_availability_time > room_availability_time[i]:\\n                    min_room_availability_time = room_availability_time[i]\\n                    min_available_time_room = i\\n            if not found_unused_room:\\n                room_availability_time[min_available_time_room] += end - start\\n                meeting_count[min_available_time_room] += 1\\n\\n        return meeting_count.index(max(meeting_count))","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"meeting-rooms-iii","has_notes":false,"flag_type":1,"frontend_id":164},{"id":1693388767,"question_id":3741,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1752166031,"status":10,"status_display":"Accepted","runtime":"231 ms","url":"/submissions/detail/1693388767/","is_pending":"Not Pending","title":"Reschedule Meetings for Maximum Free Time II","memory":"38.4 MB","code":"class Solution:\\n    def maxFreeTime(\\n        self, eventTime: int, startTime: list[int], endTime: list[int]\\n    ) -> int:\\n        n = len(startTime)\\n        q = [False] * n\\n        t1 = 0\\n        t2 = 0\\n        for i in range(n):\\n            if endTime[i] - startTime[i] <= t1:\\n                q[i] = True\\n            t1 = max(t1, startTime[i] - (0 if i == 0 else endTime[i - 1]))\\n\\n            if endTime[n - i - 1] - startTime[n - i - 1] <= t2:\\n                q[n - i - 1] = True\\n            t2 = max(\\n                t2,\\n                (eventTime if i == 0 else startTime[n - i])\\n                - endTime[n - i - 1],\\n            )\\n\\n        res = 0\\n        for i in range(n):\\n            left = 0 if i == 0 else endTime[i - 1]\\n            right = eventTime if i == n - 1 else startTime[i + 1]\\n            if q[i]:\\n                res = max(res, right - left)\\n            else:\\n                res = max(res, right - left - (endTime[i] - startTime[i]))\\n        return res","compare_result":"","title_slug":"reschedule-meetings-for-maximum-free-time-ii","has_notes":false,"flag_type":1,"frontend_id":163},{"id":1692280603,"question_id":3743,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1752081860,"status":10,"status_display":"Accepted","runtime":"72 ms","url":"/submissions/detail/1692280603/","is_pending":"Not Pending","title":"Reschedule Meetings for Maximum Free Time I","memory":"36 MB","code":"class Solution:\\n    def maxFreeTime(\\n        self, eventTime: int, k: int, startTime: List[int], endTime: List[int]\\n    ) -> int:\\n        n = len(startTime)\\n        res = 0\\n        total = [0] * (n + 1)\\n        for i in range(n):\\n            total[i + 1] = total[i] + endTime[i] - startTime[i]\\n        for i in range(k - 1, n):\\n            right = eventTime if i == n - 1 else startTime[i + 1]\\n            left = 0 if i == k - 1 else endTime[i - k]\\n            res = max(res, right - left - (total[i + 1] - total[i - k + 1]))\\n        return res","compare_result":"","title_slug":"reschedule-meetings-for-maximum-free-time-i","has_notes":false,"flag_type":1,"frontend_id":162},{"id":1690652611,"question_id":1851,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1751970463,"status":10,"status_display":"Accepted","runtime":"634 ms","url":"/submissions/detail/1690652611/","is_pending":"Not Pending","title":"Maximum Number of Events That Can Be Attended II","memory":"54.6 MB","code":"class Solution:\\n    def maxValue(self, events: List[List[int]], k: int) -> int:        \\n        n = len(events)\\n        dp = [[0] * (n + 1) for _ in range(k + 1)]\\n        events.sort()\\n        starts = [start for start, end, value in events]\\n\\n        for cur_index in range(n - 1, -1, -1):\\n            for count in range(1, k + 1):\\n                next_index = bisect_right(starts, events[cur_index][1])\\n                dp[count][cur_index] = max(dp[count][cur_index + 1], events[cur_index][2] + dp[count - 1][next_index])\\n        \\n        return dp[k][0]","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-number-of-events-that-can-be-attended-ii","has_notes":false,"flag_type":1,"frontend_id":161},{"id":1689472788,"question_id":1478,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1751887323,"status":10,"status_display":"Accepted","runtime":"175 ms","url":"/submissions/detail/1689472788/","is_pending":"Not Pending","title":"Maximum Number of Events That Can Be Attended","memory":"53.3 MB","code":"class Solution:\\n    def maxEvents(self, events: List[List[int]]) -> int:\\n        n = len(events)\\n        max_day = max(event[1] for event in events)\\n        events.sort()\\n        pq = []\\n        ans, j = 0, 0\\n        for i in range(1, max_day + 1):\\n            while j < n and events[j][0] <= i:\\n                heapq.heappush(pq, events[j][1])\\n                j += 1\\n            while pq and pq[0] < i:\\n                heapq.heappop(pq)\\n            if pq:\\n                heapq.heappop(pq)\\n                ans += 1\\n\\n        return ans","compare_result":"111111111111111111111111111111111111111111111","title_slug":"maximum-number-of-events-that-can-be-attended","has_notes":false,"flag_type":1,"frontend_id":160},{"id":1689470995,"question_id":1478,"lang":"python3","lang_name":"Python3","time":"11\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1751887201,"status":14,"status_display":"Time Limit Exceeded","runtime":"N/A","url":"/submissions/detail/1689470995/","is_pending":"Not Pending","title":"Maximum Number of Events That Can Be Attended","memory":"N/A","code":"class Solution:\\n    def maxEvents(self, events: list[list[int]]) -> int:\\n        events.sort()  # sort by start day\\n        i = 0\\n        day = 1\\n        n = len(events)\\n        attended = 0\\n        ongoing = []\\n\\n        # Maximum day any event can end\\n        last_day = max(end for _, end in events)\\n\\n        while day <= last_day:\\n            # Add events starting today\\n            while i < n and events[i][0] == day:\\n                ongoing.append(events[i][1])\\n                i += 1\\n\\n            # Remove events that expired before today\\n            ongoing = [end for end in ongoing if end >= day]\\n\\n            if ongoing:\\n                # Simulate picking the event that ends earliest\\n                min_end = min(ongoing)\\n                ongoing.remove(min_end)\\n                attended += 1\\n\\n            day += 1\\n\\n        return attended\\n","compare_result":"111111111111111111111111111111111111111111000","title_slug":"maximum-number-of-events-that-can-be-attended","has_notes":false,"flag_type":1,"frontend_id":159}],"has_next":true,"last_key":""}'
