id\\n\\n        return left\\n","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111000000000000000","title_slug":"kth-smallest-product-of-two-sorted-arrays","has_notes":false,"flag_type":1,"frontend_id":135},{"id":1675755888,"question_id":2150,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year","timestamp":1750835585,"status":14,"status_display":"Time Limit Exceeded","runtime":"N/A","url":"/submissions/detail/1675755888/","is_pending":"Not Pending","title":"Kth Smallest Product of Two Sorted Arrays","memory":"N/A","code":"class Solution:\\n    def kthSmallestProduct(self, nums1, nums2, k):\\n        products = []\\n\\n        for num1 in nums1:\\n            for num2 in nums2:\\n                products.append(num1 * num2)\\n\\n        products.sort()\\n        return products[k - 1]\\n","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111110000000000000000000000000000","title_slug":"kth-smallest-product-of-two-sorted-arrays","has_notes":false,"flag_type":1,"frontend_id":134},{"id":1674624959,"question_id":2320,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year","timestamp":1750750814,"status":10,"status_display":"Accepted","runtime":"179 ms","url":"/submissions/detail/1674624959/","is_pending":"Not Pending","title":"Find All K-Distant Indices in an Array","memory":"18.2 MB","code":"\\nclass Solution:\\n    def findKDistantIndices(self, nums: List[int], key: int, k: int) -> List[int]:\\n        sol = set()  # Use a set to avoid duplicates\\n\\n        for i in range(len(nums)):\\n            if nums[i] == key:\\n                # Add all indices j such that abs(i - j) <= k\\n                for j in range(max(0, i - k), min(len(nums), i + k + 1)):\\n                    sol.add(j)\\n\\n        return sorted(sol)\\n","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"find-all-k-distant-indices-in-an-array","has_notes":false,"flag_type":1,"frontend_id":133},{"id":1674624067,"question_id":2320,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year","timestamp":1750750759,"status":10,"status_display":"Accepted","runtime":"177 ms","url":"/submissions/detail/1674624067/","is_pending":"Not Pending","title":"Find All K-Distant Indices in an Array","memory":"18.1 MB","code":"from typing import List\\n\\nclass Solution:\\n    def findKDistantIndices(self, nums: List[int], key: int, k: int) -> List[int]:\\n        sol = set()  # Use a set to avoid duplicates\\n\\n        for i in range(len(nums)):\\n            if nums[i] == key:\\n                # Add all indices j such that abs(i - j) <= k\\n                for j in range(max(0, i - k), min(len(nums), i + k + 1)):\\n                    sol.add(j)\\n\\n        return sorted(sol)\\n","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"find-all-k-distant-indices-in-an-array","has_notes":false,"flag_type":1,"frontend_id":132},{"id":1673348387,"question_id":2202,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year","timestamp":1750658230,"status":10,"status_display":"Accepted","runtime":"3827 ms","url":"/submissions/detail/1673348387/","is_pending":"Not Pending","title":"Sum of k-Mirror Numbers","memory":"17.9 MB","code":"class Solution:\\n    def palindrom(self, s: str) -> bool:\\n        left, right = 0, len(s) - 1\\n        while left < right:\\n            if s[left] != s[right]:\\n                return False\\n            left += 1\\n            right -= 1\\n        return True\\n\\n    def converttobase(self, x: int, k: int) -> str:\\n        res = \\"\\"\\n        while x > 0:\\n            res = str(x % k) + res\\n            x //= k\\n        return res\\n\\n    def kMirror(self, k: int, n: int) -> int:\\n        def generate_palindromes(length):\\n            # Generate palindromes of a given length\\n            half_len = (length + 1) // 2\\n            start = 10**(half_len - 1)\\n            end = 10**half_len\\n            for i in range(start, end):\\n                s = str(i)\\n                if length % 2 == 0:\\n                    yield int(s + s[::-1])\\n                else:\\n                    yield int(s + s[-2::-1])\\n\\n        count = 0\\n        total = 0\\n        length = 1\\n\\n        while count < n:\\n            for p in generate_palindromes(length):\\n                if self.palindrom(self.converttobase(p, k)):\\n                    total += p\\n                    count += 1\\n                    if count == n:\\n                        return total\\n            length += 1\\n\\n        return total\\n","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"sum-of-k-mirror-numbers","has_notes":false,"flag_type":1,"frontend_id":131},{"id":1673344837,"question_id":2202,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year","timestamp":1750658040,"status":14,"status_display":"Time Limit Exceeded","runtime":"N/A","url":"/submissions/detail/1673344837/","is_pending":"Not Pending","title":"Sum of k-Mirror Numbers","memory":"N/A","code":"class Solution:\\n    def palindrom(self, y: int) -> bool:\\n        y = str(y)\\n        left, right = 0, len(y) - 1\\n        while left < right:\\n            if y[left] != y[right]:\\n                return False\\n            left += 1\\n            right -= 1\\n        return True\\n\\n    def converttobase(self, x: int, k: int) -> str:\\n        res = \\"\\"\\n        while x > 0:\\n            res = str(x % k) + res\\n            x = x // k\\n        return res\\n\\n    def kMirror(self, k: int, n: int) -> int:\\n        sum = 0\\n        count = 0\\n        b = 1\\n        while count < n:\\n            if self.palindrom(b):\\n                base_k = self.converttobase(b, k)\\n                if self.palindrom(base_k):\\n                    sum = sum + b\\n                    count += 1\\n            b += 1\\n        return sum\\n","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111000000000000000000000000","title_slug":"sum-of-k-mirror-numbers","has_notes":false,"flag_type":1,"frontend_id":130},{"id":1672473335,"question_id":2704,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year","timestamp":1750583423,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1672473335/","is_pending":"Not Pending","title":"Maximum Difference by Remapping a Digit","memory":"17.8 MB","code":"class Solution:\\n    def minMaxDifference(self, num: int) -> int:\\n        mx, mn = 0, float(\'inf\')\\n        num = list(str(num))\\n        c = set(num)\\n\\n        for i in c:\\n            a, b = 0, 0\\n            for j in range(len(num)):\\n                if num[j] == i:\\n                    a = 10 * a + 9\\n                    b = 10 * b\\n                else:\\n                    a = 10 * a + int(num[j])\\n                    b = 10 * b + int(num[j])\\n            mx = max(mx, a)\\n            mn = min(mn, b)\\n        \\n        return mx - mn\\n","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-difference-by-remapping-a-digit","has_notes":false,"flag_type":1,"frontend_id":129},{"id":1672472536,"question_id":2704,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year","timestamp":1750583357,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1672472536/","is_pending":"Not Pending","title":"Maximum Difference by Remapping a Digit","memory":"17.6 MB","code":"class Solution:\\n    def minMaxDifference(self, num: int) -> int:\\n        s = str(num)\\n\\n        # Build maximum number: replace first digit \xe2\x89\xa0 9 with 9\\n        for ch in s:\\n            if ch != \'9\':\\n                max_num = int(s.replace(ch, \'9\'))\\n                break\\n        else:\\n            max_num = int(s)  # already all 9s\\n\\n        # Build minimum number: replace first digit \xe2\x89\xa0 0 with 0\\n        for ch in s:\\n            if ch != \'0\':\\n                min_num = int(s.replace(ch, \'0\'))\\n                break\\n        else:\\n            min_num = int(s)  # already all 0s\\n\\n        return max_num - min_num\\n","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-difference-by-remapping-a-digit","has_notes":false,"flag_type":1,"frontend_id":128},{"id":1672261139,"question_id":2260,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year","timestamp":1750567936,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1672261139/","is_pending":"Not Pending","title":"Divide a String Into Groups of Size k","memory":"17.9 MB","code":"class Solution:\\n    def divideString(self, s: str, k: int, fill: str) -> List[str]:\\n        a=len(s)\\n        b=[]\\n        if a%k!=0:\\n            s=s+(fill*(k-a%k))\\n        i =0\\n        while i <len(s):\\n            b.append(s[i:i+k])\\n            i=i+k\\n        return b\\n","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"divide-a-string-into-groups-of-size-k","has_notes":false,"flag_type":1,"frontend_id":127},{"id":1671829272,"question_id":3360,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year","timestamp":1750526811,"status":10,"status_display":"Accepted","runtime":"311 ms","url":"/submissions/detail/1671829272/","is_pending":"Not Pending","title":"Minimum Deletions to Make String K-Special","memory":"18 MB","code":"class Solution:\\n    def minimumDeletions(self, word: str, k: int) -> int:\\n        freq = [0] * 26\\n        for c in word:\\n            freq[ord(c) - ord(\'a\')] += 1\\n\\n        # Remove zeros for efficiency\\n        freq = [f for f in freq if f > 0]\\n\\n        min_deletions = float(\'inf\')\\n\\n        # Try every possible target frequency\\n        for target in range(1, max(freq) + 1):\\n            deletions = 0\\n            for f in freq:\\n                if f > target + k:\\n                    deletions += f - (target + k)\\n                elif f < target:\\n                    deletions += f\\n            if deletions < min_deletions:\\n                min_deletions = deletions\\n\\n        return min_deletions\\n","compare_result":"","title_slug":"minimum-deletions-to-make-string-k-special","has_notes":false,"flag_type":1,"frontend_id":126},{"id":1670369482,"question_id":3754,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year","timestamp":1750412452,"status":10,"status_display":"Accepted","runtime":"1619 ms","url":"/submissions/detail/1670369482/","is_pending":"Not Pending","title":"Maximum Manhattan Distance After K Changes","memory":"18.1 MB","code":"class Solution:\\n    def maxDistance(self, s: str, k: int) -> int:\\n        ans = 0\\n        north = south = east = west = 0\\n        \\n        for i in range(len(s)):\\n            c = s[i]\\n            if c == \'N\':\\n                north += 1\\n            elif c == \'S\':\\n                south += 1\\n            elif c == \'E\':\\n                east += 1\\n            elif c == \'W\':\\n                west += 1\\n            \\n            x = abs(north - south)\\n            y = abs(east - west)\\n            MD = x + y\\n            dis = MD + min(2 * k, i + 1 - MD)\\n            ans = max(ans, dis)\\n        \\n        return ans","compare_result":"","title_slug":"maximum-manhattan-distance-after-k-changes","has_notes":false,"flag_type":1,"frontend_id":125},{"id":1670295852,"question_id":3754,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year","timestamp":1750407237,"status":10,"status_display":"Accepted","runtime":"1601 ms","url":"/submissions/detail/1670295852/","is_pending":"Not Pending","title":"Maximum Manhattan Distance After K Changes","memory":"18.2 MB","code":"class Solution:\\n    def maxDistance(self, s: str, k: int) -> int:\\n        ans = 0\\n        north = south = east = west = 0\\n        \\n        for i in range(len(s)):\\n            c = s[i]\\n            if c == \'N\':\\n                north += 1\\n            elif c == \'S\':\\n                south += 1\\n            elif c == \'E\':\\n                east += 1\\n            elif c == \'W\':\\n                west += 1\\n            \\n            x = abs(north - south)\\n            y = abs(east - west)\\n            MD = x + y\\n            dis = MD + min(2 * k, i + 1 - MD)\\n            ans = max(ans, dis)\\n        \\n        return ans","compare_result":"","title_slug":"maximum-manhattan-distance-after-k-changes","has_notes":false,"flag_type":1,"frontend_id":124},{"id":1670250875,"question_id":1227,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year","timestamp":1750403981,"status":10,"status_display":"Accepted","runtime":"2 ms","url":"/submissions/detail/1670250875/","is_pending":"Not Pending","title":"Number of Equivalent Domino Pairs","memory":"24.4 MB","code":"class Solution:\\n    def numEquivDominoPairs(self, dominoes: List[List[int]]) -> int:\\n        num = [0] * 100\\n        ret = 0\\n        for x, y in dominoes:\\n            val = x * 10 + y if x <= y else y * 10 + x\\n            ret += num[val]\\n            num[val] += 1\\n        return ret\\n","compare_result":"1111111111111111111","title_slug":"number-of-equivalent-domino-pairs","has_notes":false,"flag_type":1,"frontend_id":123},{"id":1669747943,"question_id":1227,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year","timestamp":1750357020,"status":10,"status_display":"Accepted","runtime":"11 ms","url":"/submissions/detail/1669747943/","is_pending":"Not Pending","title":"Number of Equivalent Domino Pairs","memory":"24.4 MB","code":"class Solution:\\n    def numEquivDominoPairs(self, dominoes: List[List[int]]) -> int:\\n        count = [0] * 100  # Because 1 <= a, b <= 9 \xe2\x86\x92 10*10 = 100\\n        result = 0\\n        for a, b in dominoes:\\n            key = 10 * min(a, b) + max(a, b)\\n            result += count[key]\\n            count[key] += 1\\n        return result\\n","compare_result":"1111111111111111111","title_slug":"number-of-equivalent-domino-pairs","has_notes":false,"flag_type":1,"frontend_id":122},{"id":1669744550,"question_id":1227,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year","timestamp":1750356835,"status":14,"status_display":"Time Limit Exceeded","runtime":"N/A","url":"/submissions/detail/1669744550/","is_pending":"Not Pending","title":"Number of Equivalent Domino Pairs","memory":"N/A","code":"class Solution:\\n    def numEquivDominoPairs(self, dominoes: List[List[int]]) -> int:\\n        count = 0\\n        for i in range(len(dominoes)):\\n            for j in range(i+1, len(dominoes)):\\n                if (dominoes[i][0] == dominoes[j][0] and dominoes[i][1] == dominoes[j][1]) or \\\\\\n                   (dominoes[i][1] == dominoes[j][0] and dominoes[i][0] == dominoes[j][1]):\\n                    count += 1\\n        return count\\n","compare_result":"1111111111111111110","title_slug":"number-of-equivalent-domino-pairs","has_notes":false,"flag_type":1,"frontend_id":121},{"id":1669113652,"question_id":119,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year","timestamp":1750316873,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1669113652/","is_pending":"Not Pending","title":"Pascal\'s Triangle II","memory":"17.8 MB","code":"class Solution:\\n    def getRow(self, rowIndex: int) -> List[int]:\\n        row = [1]\\n\\n        for i in range(1, rowIndex + 1):\\n            next_element = row[i - 1] * (rowIndex - i + 1) // i\\n            row.append(next_element)\\n\\n        return row","compare_result":"1111111111111111111111111111111111","title_slug":"pascals-triangle-ii","has_notes":false,"flag_type":1,"frontend_id":120},{"id":1668406472,"question_id":118,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year","timestamp":1750258683,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/1668406472/","is_pending":"Not Pending","title":"Pascal\'s Triangle","memory":"18 MB","code":"class Solution:\\n    def generate(self, numRows: int) -> List[List[int]]:\\n        if numRows == 1:\\n            return [[1]]\\n        elif numRows == 2:\\n            return [[1], [1, 1]]\\n\\n        arr = [[1], [1, 1]]\\n\\n        for i in range(2, numRows):\\n            prev = arr[i - 1]\\n            row = [1]\\n            for j in range(1, len(prev)):\\n                row.append(prev[j - 1] + prev[j])\\n            row.append(1)  \\n            arr.append(row)\\n\\n        return arr\\n","compare_result":"111111111111111111111111111111","title_slug":"pascals-triangle","has_notes":false,"flag_type":1,"frontend_id":119}],"has_next":true,"last_key":""}'
