MB","code":"class Solution:\\n    def minimumDistance(self, nums: List[int]) -> int:\\n        ans=float(\\"inf\\")\\n        for i in range(len(nums)-2):\\n            flag=False\\n            for j in range(i+1,len(nums)):\\n                if nums[j]!=nums[i]:\\n                    continue\\n                if flag:\\n                    break\\n                for k in range(j+1,len(nums)):\\n                    if nums[j]!=nums[k]:\\n                        continue\\n                    flag=True\\n                    temp=abs(i-j)+abs(j-k)+abs(i-k)\\n                    if temp<ans:\\n                        ans=temp\\n        return ans if ans!=float(\\"inf\\") else -1\\n\\n","compare_result":"","title_slug":"minimum-distance-between-three-equal-elements-i","has_notes":false,"flag_type":1,"frontend_id":402},{"id":1972623250,"question_id":3974,"lang":"python3","lang_name":"Python3","time":"2\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1775656506,"status":10,"status_display":"Accepted","runtime":"1608 ms","url":"/submissions/detail/1972623250/","is_pending":"Not Pending","title":"XOR After Range Multiplication Queries I","memory":"20 MB","code":"class Solution:\\n    def xorAfterQueries(self, nums: List[int], queries: List[List[int]]) -> int:\\n        \\n        MOD=(10**9)+7\\n        for i in queries:\\n            for j in range(i[0],i[1]+1,i[2]):\\n                nums[j]=(nums[j]*i[3])%(MOD)\\n        ans=nums[0]\\n        for k in range(1,len(nums)):\\n            ans=ans^nums[k]\\n        return ans","compare_result":"","title_slug":"xor-after-range-multiplication-queries-i","has_notes":false,"flag_type":1,"frontend_id":401},{"id":1969402239,"question_id":657,"lang":"python3","lang_name":"Python3","time":"2\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1775374577,"status":10,"status_display":"Accepted","runtime":"15 ms","url":"/submissions/detail/1969402239/","is_pending":"Not Pending","title":"Robot Return to Origin","memory":"19.4 MB","code":"class Solution:\\n    def judgeCircle(self, moves: str) -> bool:\\n        freq={\\"R\\":0,\\"L\\":0,\\"U\\":0,\\"D\\":0}\\n        for i in moves:\\n            freq[i]+=1\\n        return freq[\\"R\\"]==freq[\\"L\\"] and freq[\\"U\\"]==freq[\\"D\\"]","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"robot-return-to-origin","has_notes":false,"flag_type":1,"frontend_id":400},{"id":1968569808,"question_id":2197,"lang":"python3","lang_name":"Python3","time":"2\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1775304453,"status":10,"status_display":"Accepted","runtime":"380 ms","url":"/submissions/detail/1968569808/","is_pending":"Not Pending","title":"Decode the Slanted Ciphertext","memory":"27.6 MB","code":"class Solution:\\n    def decodeCiphertext(self, encodedText: str, rows: int) -> str:\\n        col=len(encodedText)//rows\\n        ans=\\"\\"\\n        for i in range(col):\\n            count=i\\n            for j in range(rows):\\n                if count<len(encodedText):\\n                    ans+=encodedText[count]\\n                count+=(col+1)\\n        return ans.rstrip()\\n","compare_result":"1111111111111111111111111111111111111111","title_slug":"decode-the-slanted-ciphertext","has_notes":false,"flag_type":1,"frontend_id":399}],"has_next":true,"last_key":""}'
