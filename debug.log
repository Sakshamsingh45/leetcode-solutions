      continue\\n                if k[j]==\\".\\" and k[i]==\\"#\\":\\n                    k[j],k[i]=\\"#\\",\\".\\"\\n                    i+=1\\n                    j+=1\\n        return [list(a) for a in zip(*boxGrid[::-1])]\\n                ","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"rotating-the-box","has_notes":false,"flag_type":1,"frontend_id":427},{"id":1995617071,"question_id":61,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1777968177,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1995617071/","is_pending":"Not Pending","title":"Rotate List","memory":"18.9 MB","code":"# Definition for singly-linked list.\\n# class ListNode:\\n#     def __init__(self, val=0, next=None):\\n#         self.val = val\\n#         self.next = next\\nclass Solution:\\n    def rotateRight(self, head: Optional[ListNode], k: int) -> Optional[ListNode]:\\n        if not head or not head.next or k == 0:\\n            return head\\n        count=0\\n        cur=head\\n        while cur is not None:\\n            count+=1\\n            cur=cur.next\\n        k%=count\\n        cur=fast=head\\n        if k==0:\\n            return head\\n        for i in range(k):\\n            fast=fast.next\\n        while fast.next is not None:\\n            cur=cur.next\\n            fast=fast.next\\n        next=cur.next\\n        fast.next=head\\n        cur.next=None\\n        head=next\\n        return head\\n","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"rotate-list","has_notes":false,"flag_type":1,"frontend_id":426},{"id":1995616336,"question_id":61,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0month, 3\xc2\xa0