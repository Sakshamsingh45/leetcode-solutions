ubmissions/detail/1854638503/","is_pending":"Not Pending","title":"Count the Number of Computer Unlocking Permutations","memory":"31.9 MB","code":"class Solution:\\n    def countPermutations(self, complexity: List[int]) -> int:\\n        count=1\\n        MOD=10**9+7\\n        for i in range(1,len(complexity)):\\n            if complexity[i]<=complexity[0]:\\n                return 0\\n        for j in range(1,len(complexity)):\\n            count=count*j%MOD\\n        return count\\n","compare_result":"","title_slug":"count-the-number-of-computer-unlocking-permutations","has_notes":null,"flag_type":1,"frontend_id":265},{"id":1854333334,"question_id":3934,"lang":"python3","lang_name":"Python3","time":"6\xc2\xa0months, 1\xc2\xa0week","timestamp":1765613336,"status":10,"status_display":"Accepted","runtime":"3 ms","url":"/submissions/detail/1854333334/","is_pending":"Not Pending","title":"Coupon Code Validator","memory":"18.2 MB","code":"class Solution:\\n    def validateCoupons(self, code: List[str], businessLine: List[str], isActive: List[bool]) -> List[str]:\\n        e, g, p, r = [], [], [], []\\n        category={\\"electronics\\", \\"grocery\\", \\"pharmacy\\", \\"restaurant\\"}\\n        for i in range(len(code)):\\n            a=1\\n            if businessLine[i] in category and isActive[i]==True and code[i]!=\\"\\" :\\n                for j in code[i]:\\n                    if j.isalnum() or j==\\"_\\":\\n                        continue\\n                    else:\\n                        a=0\\n                        break\\n                if a!=0:\\n                    if businessLine[i] == \\"grocery\\": g.append(code[i])\\n                    if businessLine[i] == \\"electronics\\": e.append(code[i])\\n                    if businessLine[i] == \\"pharmacy\\": p.append(code[i])\\n                    if businessLine[i] == \\"restaurant\\": r.append(code[i])\\n        \\n        return sorted(e) + sorted(g) + sorted(p) + sorted(r)\\n\\n\\n\\n\\n\\n        ","compare_result":"","title_slug":"coupon-code-validator","has_notes":null,"flag_type":1,"frontend_id":264},{"id":1854292324,"question_id":3934,"lang":"python3","lang_name":"Python3","time":"6\xc2\xa0months, 1\xc2\xa0week","timestamp":1765609595,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1854292324/","is_pending":"Not Pending","title":"Coupon Code Validator","memory":"N/A","code":"class Solution:\\n    def validateCoupons(self, code: List[str], businessLine: List[str], isActive: List[bool]) -> List[str]:\\n        sol=[]\\n        category={\\"electronics\\", \\"grocery\\", \\"pharmacy\\", \\"restaurant\\"}\\n        for i in range(len(code)):\\n            a=1\\n            if businessLine[i] in category and isActive[i]==True and code[i]!=\\"\\" :\\n                for j in code[i]:\\n                    if 47<ord(j)<58 or 64<ord(j)<91 or 96<ord(j)<123 or j==\\"_\\":\\n                        continue\\n                    else:\\n                        a=0\\n                        break\\n                if a!=0:\\n                    sol.append(code[i])\\n        sol.sort()\\n        return sol\\n\\n\\n\\n\\n\\n        ","compare_result":"","title_slug":"coupon-code-validator","has_notes":false,"flag_type":1,"frontend_id":263},{"id":1853870418,"question_id":3721,"lang":"python3","lang_name":"Python3","time":"6\xc2\xa0months, 1\xc2\xa0week","timestamp":1765555981,"status":10,"status_display":"Accepted","runtime":"37 ms","url":"/submissions/detail/1853870418/","is_pending":"Not Pending","title":"Count Mentions Per User","memory":"18.1 MB","code":"class Solution:\\n    def countMentions(\\n        self, numberOfUsers: int, events: List[List[str]]\\n    ) -> List[int]:\\n        events.sort(key=lambda e: (int(e[1]), e[0] == \\"MESSAGE\\"))\\n        count = [0] * numberOfUsers\\n        next_online_time = [0] * numberOfUsers\\n        for event in events:\\n            cur_time = int(event[1])\\n            if event[0] == \\"MESSAGE\\":\\n                if event[2] == \\"ALL\\":\\n                    for i in range(numberOfUsers):\\n                        count[i] += 1\\n                elif event[2] == \\"HERE\\":\\n                    for i, t in enumerate(next_online_time):\\n                        if t <= cur_time:\\n                            count[i] += 1\\n                else:\\n                    for idx in event[2].split():\\n                        count[int(idx[2:])] += 1\\n            else:\\n                next_online_time[int(event[2])] = cur_time + 60\\n        return count","compare_result":"","title_slug":"count-mentions-per-user","has_notes":false,"flag_type":1,"frontend_id":262},{"id":1852709773,"question_id":3819,"lang":"python3","lang_name":"Python3","time":"6\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1765440005,"status":10,"status_display":"Accepted","runtime":"307 ms","url":"/submissions/detail/1852709773/","is_pending":"Not Pending","title":"Count Covered Buildings","memory":"62.2 MB","code":"from typing import List\\n\\nclass Solution:\\n    def countCoveredBuildings(self, n: int, buildings: List[List[int]]) -> int:\\n        count = 0\\n        xmax, xmin, ymax, ymin = {}, {}, {}, {}\\n        for x, y in buildings:\\n            if x in xmax:\\n                if y > xmax[x]:\\n                    xmax[x] = y\\n                if y < xmin[x]:\\n                    xmin[x] = y\\n            else:\\n                xmax[x] = y\\n                xmin[x] = y\\n            if y in ymax:\\n                if x > ymax[y]:\\n                    ymax[y] = x\\n                if x < ymin[y]:\\n                    ymin[y] = x\\n            else:\\n                ymax[y] = x\\n                ymin[y] = x\\n        for x, y in buildings:\\n            if xmin[x] < y < xmax[x] and ymin[y] < x < ymax[y]:\\n                count += 1\\n\\n        return count","compare_result":"","title_slug":"count-covered-buildings","has_notes":false,"flag_type":1,"frontend_id":261},{"id":1852159866,"question_id":3864,"lang":"python3","lang_name":"Python3","time":"6\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1765382626,"status":10,"status_display":"Accepted","runtime":"21 ms","url":"/submissions/detail/1852159866/","is_pending":"Not Pending","title":"Count the Number of Computer Unlocking Permutations","memory":"31.9 MB","code":"class Solution:\\n    def countPermutations(self, complexity: List[int]) -> int:\\n        n=len(complexity)\\n        for i in range(1,n):\\n            if complexity[i]<=complexity[0]:\\n                return 0\\n        ans,mod=1,10**9+7\\n        for i in range(2,n):\\n            ans=ans*i%mod\\n        return ans\\n        \\n\\n\\n\\n        ","compare_result":"","title_slug":"count-the-number-of-computer-unlocking-permutations","has_notes":null,"flag_type":1,"frontend_id":260},{"id":1851658797,"question_id":2032,"lang":"python3","lang_name":"Python3","time":"6\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1765341469,"status":10,"status_display":"Accepted","runtime":"12 ms","url":"/submissions/detail/1851658797/","is_pending":"Not Pending","title":"Largest Odd Number in String","memory":"19 MB","code":"class Solution:\\n    def largestOddNumber(self, num: str) -> str:\\n        for i in range (-1,-len(num)-1,-1):\\n            if int(num[i])%2!=0:\\n                return num[0:len(num)+i+1]\\n        return \\"\\"","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"largest-odd-number-in-string","has_notes":false,"flag_type":1,"frontend_id":259}],"has_next":true,"last_key":""}'
