:"Accepted","runtime":"323 ms","url":"/submissions/detail/1799106369/","is_pending":"Not Pending","title":"Maximum Total Damage With Spell Casting","memory":"32.1 MB","code":"class Solution:\\n    def maximumTotalDamage(self, power: List[int]) -> int:\\n        if not power:\\n            return 0\\n\\n        power.sort()\\n\\n        # Step 1: group duplicates and store total damage per unique power\\n        nums = []\\n        damage = []\\n        cur = power[0]\\n        total = power[0]\\n        for x in power[1:]:\\n            if x == cur:\\n                total += x\\n            else:\\n                nums.append(cur)\\n                damage.append(total)\\n                cur = x\\n                total = x\\n        nums.append(cur)\\n        damage.append(total)\\n\\n        # Step 2: dynamic programming\\n        n = len(nums)\\n        dp = [0] * n\\n        dp[0] = damage[0]\\n\\n        for i in range(1, n):\\n            j = i - 1\\n            # find last non-conflicting index (nums[j] <= nums[i] - 3)\\n            while j >= 0 and nums[i] - nums[j] < 3:\\n                j -= 1\\n            take = damage[i] + (dp[j] if j >= 0 else 0)\\n            skip = dp[i - 1]\\n            dp[i] = max(take, skip)\\n\\n        return dp[-1]\\n","compare_result":"","title_slug":"maximum-total-damage-with-spell-casting","has_notes":false,"flag_type":1,"frontend_id":236},{"id":1799060948,"question_id":3437,"lang":"python3","lang_name":"Python3","time":"8\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1760248962,"status":10,"status_display":"Accepted","runtime":"1061 ms","url":"/submissions/detail/1799060948/","is_pending":"Not Pending","title":"Maximum Total Damage With Spell Casting","memory":"31.8 MB","code":"from typing import List\\n\\nclass Solution:\\n    def maximumTotalDamage(self, power: List[int]) -> int:\\n        if not power:\\n            return 0\\n\\n        # Step 1: sort and group duplicates into (value, total_damage_for_value)\\n        power.sort()\\n        nums = []     # unique values\\n        damage = []   # total damage for each unique value\\n        cur = power[0]\\n        tot = power[0]\\n        for x in power[1:]:\\n            if x == cur:\\n                tot += x\\n            else:\\n                nums.append(cur)\\n                damage.append(tot)\\n                cur = x\\n                tot = x\\n        nums.append(cur)\\n        damage.append(tot)\\n\\n        # Step 2: DP where dp[i] = best damage using nums[0..i]\\n        n = len(nums)\\n        dp = [0] * n\\n        dp[0] = damage[0]\\n\\n        # helper: find rightmost index j < i such that nums[j] <= nums[i] - 3\\n        def find_last_non_conflicting(nums, i):\\n            target = nums[i] - 3\\n            lo, hi = 0, i - 1\\n            ans = -1\\n            while lo <= hi:\\n                mid = (lo + hi) // 2\\n                if nums[mid] <= target:\\n                    ans = mid\\n                    lo = mid + 1\\n                else:\\n                    hi = mid - 1\\n            return ans\\n\\n        for i in range(1, n):\\n            j = find_last_non_conflicting(nums, i)\\n            take = damage[i] + (dp[j] if j != -1 else 0)\\n            skip = dp[i - 1]\\n            dp[i] = max(take, skip)\\n\\n        return dp[-1]\\n","compare_result":"","title_slug":"maximum-total-damage-with-spell-casting","has_notes":false,"flag_type":1,"frontend_id":235},{"id":1797697215,"question_id":3383,"lang":"python3","lang_name":"Python3","time":"8\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1760127544,"status":10,"status_display":"Accepted","runtime":"1170 ms","url":"/submissions/detail/1797697215/","is_pending":"Not Pending","title":"Taking Maximum Energy From the Mystic Dungeon","memory":"31.1 MB","code":"class Solution:\\n    def maximumEnergy(self, energy: List[int], k: int) -> int:\\n        n = len(energy)\\n        ans = -inf\\n\\n        for i in range(n - k, n):\\n            total = 0\\n            j = i\\n            while j >= 0:\\n                total += energy[j]\\n                ans = max(ans, total)\\n                j -= k\\n\\n        return ans","compare_result":"","title_slug":"taking-maximum-energy-from-the-mystic-dungeon","has_notes":false,"flag_type":1,"frontend_id":234},{"id":1794924369,"question_id":2392,"lang":"python3","lang_name":"Python3","time":"8\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1759899983,"status":10,"status_display":"Accepted","runtime":"515 ms","url":"/submissions/detail/1794924369/","is_pending":"Not Pending","title":"Successful Pairs of Spells and Potions","memory":"42.9 MB","code":"class Solution:\\n    def successfulPairs(self, spells: List[int], potions: List[int], success: int) -> List[int]:\\n        potions.sort()\\n        n = len(potions)\\n        pairs = []\\n\\n        for s in spells:\\n            # Minimum potion value required\\n            threshold = (success + s - 1) // s  # same as ceil(success / s)\\n\\n            # --- Manual binary search ---\\n            left, right = 0, n - 1\\n            while left <= right:\\n                mid = (left + right) // 2\\n                if potions[mid] < threshold:\\n                    left = mid + 1\\n                else:\\n                    right = mid - 1\\n\\n            # After the loop, \'left\' is the first index where potions[left] >= threshold\\n            pairs.append(n - left)\\n\\n        return pairs\\n","compare_result":"111111111111111111111111111111111111111111111111111111111","title_slug":"successful-pairs-of-spells-and-potions","has_notes":false,"flag_type":1,"frontend_id":233},{"id":1794921445,"question_id":2392,"lang":"python3","lang_name":"Python3","time":"8\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1759899808,"status":14,"status_display":"Time Limit Exceeded","runtime":"N/A","url":"/submissions/detail/1794921445/","is_pending":"Not Pending","title":"Successful Pairs of Spells and Potions","memory":"N/A","code":"class Solution:\\n    def successfulPairs(self, spells: List[int], potions: List[int], success: int) -> List[int]:\\n        pairs=[]\\n        potions.sort()\\n        for i in range (len(spells)):\\n            j=0\\n            while j < len(potions):\\n                if spells[i]*potions[j]>=success:\\n                    pairs.append(len(potions)-j)\\n                    break\\n                elif j==len(potions)-1 :\\n                    pairs.append(0)\\n                j+=1\\n        return pairs","compare_result":"111111111111111111111111111111111111111111111111110000000","title_slug":"successful-pairs-of-spells-and-potions","has_notes":false,"flag_type":1,"frontend_id":232},{"id":1792344734,"question_id":15,"lang":"python3","lang_name":"Python3","time":"8\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1759681699,"status":10,"status_display":"Accepted","runtime":"587 ms","url":"/submissions/detail/1792344734/","is_pending":"Not Pending","title":"3Sum","memory":"20.6 MB","code":"class Solution:\\n    def threeSum(self, nums: List[int]) -> List[List[int]]:\\n        nums.sort()\\n        n = len(nums)\\n        res = []\\n        \\n        for i in range(n):\\n            # Skip duplicate elements for i\\n            if i > 0 and nums[i] == nums[i - 1]:\\n                continue\\n            \\n            l, r = i + 1, n - 1\\n            while l < r:\\n                s = nums[i] + nums[l] + nums[r]\\n                \\n                if s == 0:\\n                    res.append([nums[i], nums[l], nums[r]])\\n                    l += 1\\n                    r -= 1\\n                    # Skip duplicates for l and r\\n                    while l < r and nums[l] == nums[l - 1]:\\n                        l += 1\\n                    while l < r and nums[r] == nums[r + 1]:\\n                        r -= 1\\n                elif s < 0:\\n                    l += 1\\n                else:\\n                    r -= 1\\n        \\n        return res\\n","compare_result":"","title_slug":"3sum","has_notes":false,"flag_type":1,"frontend_id":231},{"id":1790755177,"question_id":11,"lang":"python3","lang_name":"Python3","time":"8\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1759556619,"status":10,"status_display":"Accepted","runtime":"91 ms","url":"/submissions/detail/1790755177/","is_pending":"Not Pending","title":"Container With Most Water","memory":"28.6 MB","code":"class Solution:\\n    def maxArea(self, height: List[int]) -> int:\\n        maxcount=0\\n        left,right=0,len(height)-1\\n        while left<right:\\n            if (min(height[left],height[right])*(right-left))>maxcount:\\n                maxcount=min(height[left],height[right])*(right-left)\\n            if height[right]<height[left]:\\n                right-=1\\n            elif height[right]>height[left]:\\n                left+=1\\n            else:\\n                left+=1\\n        return maxcount","compare_result":"11111111111111111111111111111111111111111111111111111111111111111","title_slug":"container-with-most-water","has_notes":false,"flag_type":1,"frontend_id":230},{"id":1789398937,"question_id":14,"lang":"python3","lang_name":"Python3","time":"8\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1759423239,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1789398937/","is_pending":"Not Pending","title":"Longest Common Prefix","memory":"18 MB","code":"class Solution:\\n    def longestCommonPrefix(self, strs: List[str]) -> str:\\n        strs.sort()\\n        if strs[0]==strs[-1]:\\n            return strs[0]\\n        i=0\\n        maxs=\\"\\"\\n        while i<len(strs[0]):\\n            s1=strs[0]\\n            s2=strs[-1]\\n            if s1[i]==s2[i]:\\n                maxs+=s1[i]\\n            else:\\n                break\\n            i+=1\\n        return maxs\\n        \\n\\n        ","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_