,"question_id":3773,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months","timestamp":1769154173,"status":10,"status_display":"Accepted","runtime":"4 ms","url":"/submissions/detail/1894093555/","is_pending":"Not Pending","title":"Minimum Pair Removal to Sort Array I","memory":"19.6 MB","code":"class Solution:\\n    def minimumPairRemoval(self, nums: List[int]) -> int:\\n        count = 0\\n\\n        while len(nums) > 1:\\n            isAscending = True\\n            minSum = float(\\"inf\\")\\n            targetIndex = -1\\n\\n            for i in range(len(nums) - 1):\\n                pair_sum = nums[i] + nums[i + 1]\\n\\n                if nums[i] > nums[i + 1]:\\n                    isAscending = False\\n\\n                if pair_sum < minSum:\\n                    minSum = pair_sum\\n                    targetIndex = i\\n\\n            if isAscending:\\n                break\\n\\n            count += 1\\n            nums[targetIndex] = minSum\\n            nums.pop(targetIndex + 1)\\n\\n        return count","compare_result":"","title_slug":"minimum-pair-removal-to-sort-array-i","has_notes":false,"flag_type":1,"frontend_id":314},{"id":1893244090,"question_id":3773,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months","timestamp":1769085787,"status":15,"status_display":"Runtime Error","runtime":"N/A","url":"/submissions/detail/1893244090/","is_pending":"Not Pending","title":"Minimum Pair Removal to Sort Array I","memory":"N/A","code":"class Solution:\\n    def minimumPairRemoval(self, nums: List[int]) -> int:\\n        count=0\\n        i=0\\n        minsum=float(\\"inf\\")\\n        j,k=0,0\\n        while True:\\n            if i+1>=len(nums) and minsum==float(\'inf\') :\\n                break\\n            if i+1>=len(nums):\\n                nums[j]=minsum\\n                nums.pop(k)\\n                minsum=float(\'inf\')\\n                j,k,i=0,0,0\\n                count+=1\\n            if nums[i]>=nums[i+1]:\\n                \\n            else:\\n                tempsum=nums[i]+nums[i+1]\\n            if tempsum < minsum:\\n                minsum=tempsum\\n                j,k=i,i+1\\n            i+=1\\n        return count\\n            \\n            \\n        ","compare_result":"","title_slug":"minimum-pair-removal-to-sort-array-i","has_notes":false,"flag_type":1,"frontend_id":313},{"id":1892587018,"question_id":1,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months","timestamp":1769025517,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1892587018/","is_pending":"Not Pending","title":"Two Sum","memory":"20.6 MB","code":"class Solution:\\n    def twoSum(self, nums: List[int], target: int) -> List[int]:\\n        dict = {}\\n        for i, n in enumerate(nums):\\n            diff = target - n\\n            if diff in dict:\\n                return [dict[diff], i]\\n            else:\\n                dict[n] = i\\n        return []\\n        ","compare_result":"111111111111111111111111111111111111111111111111111111111111111","title_slug":"two-sum","has_notes":false,"flag_type":1,"frontend_id":312},{"id":1890284929,"question_id":219,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months","timestamp":1768850275,"status":10,"status_display":"Accepted","runtime":"34 ms","url":"/submissions/detail/1890284929/","is_pending":"Not Pending","title":"Contains Duplicate II","memory":"36.8 MB","code":"class Solution:\\n    def containsNearbyDuplicate(self, nums: List[int], k: int) -> bool:\\n        dict={}\\n        for i,val in enumerate(nums):\\n            if val in dict and i-dict[val]<=k:\\n                return True\\n            else:\\n                dict[val]=i\\n\\n        return False","compare_result":"11111111111111111111111111111111111111111111111111111111111111111","title_slug":"contains-duplicate-ii","has_notes":false,"flag_type":1,"frontend_id":311},{"id":1890265094,"question_id":1311,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months","timestamp":1768848949,"status":14,"status_display":"Time Limit Exceeded","runtime":"N/A","url":"/submissions/detail/1890265094/","is_pending":"Not Pending","title":"Largest Magic Square","memory":"N/A","code":"class Solution:\\n    def largestMagicSquare(self, grid: List[List[int]]) -> int:\\n        def check(l, t, y):\\n            r = {}\\n            c = {}\\n            d1 = d2 = 0\\n            for q in range(y):\\n                for w in range(y):\\n                    if q == w:\\n                        d1+=grid[l+q][t+w]\\n                    if q + w == y - 1:\\n                        d2+=grid[l+q][t+w]\\n                    r[q] = r.get(q, 0) + grid[l+q][t+w]\\n                    c[w] = c.get(w, 0) + grid[l+q][t+w]\\n            target=r[0]\\n            for z in range(len(c)):\\n                if c[z] == target and  r[z]==target:\\n                    continue\\n                else:\\n                    return False\\n            if d2==target and d1==target:\\n                return True\\n            return False\\n\\n        column, row = len(grid[0]), len(grid)\\n        mins = min(column, row)\\n        ri, cj = 0, 0\\n        while mins > 1:\\n            if check(ri, cj, mins):\\n                return mins\\n            if ri + mins < row:\\n                ri += 1\\n            else:\\n                if cj + mins < column:\\n                    cj += 1\\n                    ri = 0\\n                else:\\n                    mins -= 1\\n                    ri, cj = 0, 0\\n        return mins\\n","compare_result":"11111111111111111111111111111111111111111111111111111111100000000000000000000000","title_slug":"largest-magic-square","has_notes":false,"flag_type":1,"frontend_id":310},{"id":1888457819,"question_id":4079,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months, 1\xc2\xa0week","timestamp":1768706977,"status":14,"status_display":"Time Limit Exceeded","runtime":"N/A","url":"/submissions/detail/1888