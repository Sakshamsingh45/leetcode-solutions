ot Pending","title":"Vowel-Consonant Score","memory":"19.4 MB","code":"class Solution:\\n    def vowelConsonantScore(self, s: str) -> int:\\n        v=0\\n        c=0\\n        a={\\"a\\",\\"e\\",\\"i\\",\\"o\\",\\"u\\"}\\n        for i in s:\\n            if i in a:\\n                v+=1\\n            elif i.isalpha():\\n                c+=1\\n        return 0 if c==0 else v//c\\n                ","compare_result":"","title_slug":"vowel-consonant-score","has_notes":false,"flag_type":1,"frontend_id":307},{"id":1887968699,"question_id":4190,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months, 1\xc2\xa0week","timestamp":1768664898,"status":10,"status_display":"Accepted","runtime":"59 ms","url":"/submissions/detail/1887968699/","is_pending":"Not Pending","title":"Minimum Operations to Reach Target Array","memory":"33.6 MB","code":"class Solution:\\n    def minOperations(self, nums: List[int], target: List[int]) -> int:\\n        bad=set()\\n        for i in range(len(nums)):\\n            if nums[i]!=target[i]:\\n                bad.add(nums[i])\\n        return len(bad)","compare_result":"","title_slug":"minimum-operations-to-reach-target-array","has_notes":false,"flag_type":1,"frontend_id":306},{"id":1887966908,"question_id":4190,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months, 1\xc2\xa0week","timestamp":1768664825,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1887966908/","is_pending":"Not Pending","title":"Minimum Operations to Reach Target Array","memory":"N/A","code":"class Solution:\\n    def minOperations(self, nums: List[int], target: List[int]) -> int:\\n        bad=set()\\n        for i in range(len(nums)):\\n            if nums[i]!=target[i]:\\n                bad.add(nums[1])\\n        return len(bad)","compare_result":"","title_slug":"minimum-operations-to-reach-target-array","has_notes":false,"flag_type":1,"frontend_id":305},{"id":1887936846,"question_id":4187,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months, 1\xc2\xa0week","timestamp":1768663663,"status":10,"status_display":"Accepted","runtime":"59 ms","url":"/submissions/detail/1887936846/","is_pending":"Not Pending","title":"Best Reachable Tower","memory":"62.5 MB","code":"class Solution:\\n    def bestTower(self, towers: List[List[int]], center: List[int], radius: int) -> List[int]:\\n        \\n        max_reachable=None\\n        for i in towers:\\n            if abs(i[0]-center[0])+abs(i[1]-center[1])<=radius:\\n                reachable=i\\n            else:\\n                continue\\n            if max_reachable is None or reachable[2]>max_reachable[2]:\\n                max_reachable=reachable\\n            elif reachable[2]==max_reachable[2]:\\n                if (reachable[0]<max_reachable[0]) or (reachable[0]==max_reachable[0] and reachable[1]<max_reachable[1]):\\n                    max_reachable=reachable\\n        if max_reachable is None:\\n            return [-1,-1]\\n        return [max_reachable[0],max_reachable[1]]","compare_result":"","title_slug":"best-reachable-tower","has_notes":false,"flag_type":1,"frontend_id":304},{"id":1886129905,"question_id":5,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months, 1\xc2\xa0week","timestamp":1768501318,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1886129905/","is_pending":"Not Pending","title":"Longest Palindromic Substring","memory":"N/A","code":"class Solution:\\n    def longestPalindrome(self, s: str) -> str:\\n        def check(i, j):\\n            left = i\\n            right = j - 1\\n\\n            while left < right:\\n                if s[left] != s[right]:\\n                    return False\\n\\n                left += 1\\n                right -= 1\\n\\n            return True\\n\\n        for start in range(len(s)):\\n            for length in range(len(s),start+1,-1):\\n                if check(start,length):\\n                    return s[start :length]\\n\\n        return \\"\\"","compare_result":"11001111110111111011111001101101111110111001101000000000001001000000000000000011111111111111111110000101011101010101010101010110101010101000001","title_slug":"longest-palindromic-substring","has_notes":false,"flag_type":1,"frontend_id":303},{"id":1885213588,"question_id":5,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months, 1\xc2\xa0week","timestamp":1768420916,"status":10,"status_display":"Accepted","runtime":"2728 ms","url":"/submissions/detail/1885213588/","is_pending":"Not Pending","title":"Longest Palindromic Substring","memory":"19.6 MB","code":"class Solution:\\n    def longestPalindrome(self, s: str) -> str:\\n        def check(i, j):\\n            left = i\\n            right = j - 1\\n\\n            while left < right:\\n                if s[left] != s[right]:\\n                    return False\\n\\n                left += 1\\n                right -= 1\\n\\n            return True\\n\\n        for length in range(len(s), 0, -1):\\n            for start in range(len(s) - length + 1):\\n                if check(start, start + length):\\n                    return s[start : start + length]\\n\\n        return \\"\\"","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"longest-palindromic-substring","has_notes":false,"flag_type":1,"frontend_id":302},{"id":1884155441,"question_id":3763,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months, 1\xc2\xa0week","timestamp":1768329241,"status":10,"status_display":"Accepted","runtime":"1655 ms","url":"/submissions/detail/1884155441/","is_pending":"Not Pending","title":"Separate Squares I","memory":"48.4 MB","code":"class Solution:\\n    def separateSquares(self, squares: List[List[int]]) -> float:\\n        max_y, total_area = 0, 0\\n        for x, y, l in squares:\\n            total_area += l**2\\n            max_y = max(max_y, y + l)\\n\\n        def check(limit_y):\\n            area = 0\\n            for x, y, l in squares:\\n                if y < limit_y:\\n                    area += l * min(limit_y - y, l)\\n            return area >= total_area / 2\\n\\n        lo, hi = 0, max_y\\n        eps = 1e-5\\n        while abs(hi - lo) > eps:\\n            mid = (hi + lo) / 2\\n            if check(mid):\\n                hi = mid\\n            else:\\n                lo = mid\\n\\n        return hi","compare_result":"","title_slug":"separate-squares-i","has_notes":false,"flag_type":1,"frontend_id":301},{"id":1882806068,"question_id":1395,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months, 1\xc2\xa0week","timestamp":1768224930,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1882806068/","is_pending":"Not Pending","title":"Minimum Time Visiting All Points","memory":"19.5 MB","code":"class Solution:\\n    def minTimeToVisitAllPoints(self, points: List[List[int]]) -> int:\\n        count=0\\n        for i in range(len(points)-1):\\n            dx=abs(points[i][0]-points[i+1][0])\\n            dy=abs(points[i][1]-points[i+1][1])\\n            count+=max(dx,dy)\\n        return count\\n","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"minimum-time-visiting-all-points","has_notes":false,"flag_type":1,"frontend_id":300},{"id":1881353038,"question_id":4129,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1768102872,"status":10,"status_display":"Accepted","runtime":"235 ms","url":"/submissions/detail/1881353038/","is_pending":"Not Pending","title":"Number of Centered Subarrays","memory":"19.4 MB","code":"class Solution:\\n    def centeredSubarrays(self, nums: List[int]) -> int:\\n        count=0\\n        for i in range(len(nums)):\\n            count+=1\\n            temp=nums[i]\\n            seen=set()\\n            seen.add(nums[i])\\n            for j in range(i+1,len(nums)):\\n                temp+=nums[j]\\n                seen.add(nums[j])\\n                if temp in seen:\\n                    count+=1\\n                \\n        return count\\n                    \\n                \\n        \\n        ","compare_result":"","title_slug":"number-of-centered-subarrays","has_notes":false,"flag_type":1,"frontend_id":299}],"has_next":true,"last_key":""}'
