=len(s)\\n        for i in range(n):\\n            if s==goal:\\n                return True\\n            temp=s[-1]\\n            s.pop()\\n            s.insert(0,temp)\\n        return False","compare_result":"11111111110000000000000000000000000000000000000000000000000000","title_slug":"rotate-string","has_notes":false,"flag_type":1,"frontend_id":421},{"id":1993971809,"question_id":812,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1777792777,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1993971809/","is_pending":"Not Pending","title":"Rotate String","memory":"N/A","code":"class Solution:\\n    def rotateString(self, s: str, goal: str) -> bool:\\n        if len(s)!=len(goal):\\n            return False\\n        s,goal=list(s),list(goal)\\n        c=goal.index(s[0])\\n        n=len(s)\\n        for i in range(n):\\n            if s[i]!=goal[c%n]:\\n                return False\\n            c+=1\\n        return True","compare_result":"11111111000000000000000000000000000000000000000000000000000000","title_slug":"rotate-string","has_notes":false,"flag_type":1,"frontend_id":420},{"id":1993605223,"question_id":804,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1777750354,"status":10,"status_display":"Accepted","runtime":"51 ms","url":"/submissions/detail/1993605223/","is_pending":"Not Pending","title":"Rotated Digits","memory":"19.4 MB","code":"class Solution:\\n    def rotatedDigits(self, n: int) -> int:\\n        valid = {\'0\',\'1\',\'2\',\'5\',\'6\',\'8\',\'9\'}\\n        diff = {\'2\',\'5\',\'6\',\'9\'}\\n        \\n        count = 0\\n        \\n        for i in range(1, n+1):\\n            s = str(i)\\n            \\n            if any(ch not in valid for ch in s):\\n                continue\\n            \\n            if any(ch in diff for ch in s):\\n                count += 1\\n        \\n        return count","compare_result":"