,"title":"Best Time to Buy and Sell Stock using Strategy","memory":"N/A","code":"class Solution:\\n    def maxProfit(self, prices: List[int], strategy: List[int], k: int) -> int:\\n        n = len(prices)\\n        p = [0] * (n + 1)\\n        for i in range(n):\\n            p[i + 1] = p[i] + prices[i] * strategy[i]\\n        base_profit = p[n]\\n        max_extra = 0\\n        a = 0\\n        while a + k <= n:\\n            extra = 0\\n            for i in range(a, a + k // 2):\\n                extra -= prices[i] * strategy[i]\\n            for i in range(a + k // 2, a + k):\\n                extra += prices[i] * (1 - strategy[i])\\n            max_extra = max(max_extra, extra)\\n            a += 1\\n\\n        return base_profit + max_extra","compare_result":"","title_slug":"best-time-to-buy-and-sell-stock-using-strategy","has_notes":false,"flag_type":1,"frontend_id":273},{"id":1858705812,"question_id":3980,"lang":"python3","lang_name":"Python3","time":"6\xc2\xa0months, 1\xc2\xa0week","timestamp":1766043112,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1858705812/","is_pending":"Not Pending","title":"Best Time to Buy and Sell Stock using Strategy","memory":"N/A","code":"class Solution:\\n    def maxProfit(self, prices: List[int], strategy: List[int], k: int) -> int:\\n        a=set()\\n        actualprofit=0\\n        for i in range(len(prices)):\\n            actualprofit+=prices[i]*strategy[i]\\n            if i+k-1<len(prices):\\n                b=1\\n                op2profit=0\\n                while b<=k:\\n                    if b<k/2:\\n                        pass\\n                    else:\\n                        op2profit+=prices[i+b-1]\\n                    b+=1\\n                a.add(op2profit)\\n        return max(actualprofit,max(a))\\n\\n\\n        ","compare_result":"","title_slug":"best-time-to-buy-and-sell-stock-using-strategy","has_notes":false,"flag_type":1,"frontend_id":272},{"id":1856204339,"question_id":2233,"lang":"python3","lang_name":"Python3","time":"6\xc2\xa0months, 1\xc2\xa0week","timestamp":1765801042,"status":10,"status_display":"Accepted","runtime":"66 ms","url":"/submissions/detail/1856204339/","is_pending":"Not Pending","title":"Number of Smooth Descent Periods of a Stock","memory":"29.9 MB","code":"class Solution:\\n    def getDescentPeriods(self, prices: List[int]) -> int:\\n        count = 0\\n        length = 0\\n        for i in range(len(prices)):\\n            if i > 0 and prices[i - 1] - 1 == prices[i]:\\n                length += 1\\n            else:\\n                length = 1\\n            count += length\\n        return count","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"number-of-smooth-descent-periods-of-a-stock","has_notes":false,"flag_type":1,"frontend_id":271},{"id":1855939049,"question_id":2233,"lang":"python3","lang_name":"Python3","time":"6\xc2\xa0months, 1\xc2\xa0week","timestamp":1765776132,"status":14,"status_display":"Time Limit Exceeded","runtime":"N/A","url":"/submissions/detail/1855939049/","is_pending":"Not Pending","title":"Number of Smooth Descent Periods of a Stock","memory":"N/A","code":"class Solution:\\n    def getDescentPeriods(self, prices: List[int]) -> int:\\n        count=0\\n        for i in range(len(prices)):\\n            maxp=prices[i]\\n            count+=1\\n            for j in range(i+1,len(prices)):\\n                if maxp-1!=prices[j]:\\n                    break\\n                count+=1\\n                maxp=prices[j]\\n        return count\\n\\n                \\n\\n\\n\\n\\n        ","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111100","title_slug":"number-of-smooth-descent-periods-of-a-stock","has_