s_notes":false,"flag_type":1,"frontend_id":197},{"id":1732774715,"question_id":1894,"lang":"python3","lang_name":"Python3","time":"10\xc2\xa0months, 1\xc2\xa0week","timestamp":1755019990,"status":10,"status_display":"Accepted","runtime":"34 ms","url":"/submissions/detail/1732774715/","is_pending":"Not Pending","title":"Merge Strings Alternately","memory":"17.7 MB","code":"class Solution:\\n    def mergeAlternately(self, word1: str, word2: str) -> str:\\n        final=\'\'\\n        for i in range(min(len(word1),len(word2))):\\n            final+= word1[i]+word2[i]\\n        i+=1\\n        if len(word1)>len(word2):\\n            while i<len(word1):\\n                final+=word1[i]\\n                i+=1\\n        else:\\n            while i<len(word2):\\n                final+=word2[i]\\n                i+=1\\n        return final\\n\\n","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"merge-strings-alternately","has_notes":false,"flag_type":1,"frontend_id":196},{"id":1720501503,"question_id":2689,"lang":"python3","lang_name":"Python3","time":"10\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1754131637,"status":10,"status_display":"Accepted","runtime":"119 ms","url":"/submissions/detail/1720501503/","is_pending":"Not Pending","title":"Rearranging Fruits","memory":"47.3 MB","code":"class Solution:\\n    def minCost(self, basket1: List[int], basket2: List[int]) -> int:\\n        freq = {}\\n        freq1 = {}\\n        freq2 = {}\\n\\n        # Build frequency maps\\n        for x in basket1:\\n            freq[x] = freq.get(x, 0) + 1\\n            freq1[x] = freq1.get(x, 0) + 1\\n        for x in basket2:\\n            freq[x] = freq.get(x, 0) + 1\\n            freq2[x] = freq2.get(x, 0) + 1\\n\\n        # If any item appears an odd number of times, return -1\\n        for v in freq.values():\\n            if v % 2 != 0:\\n                return -1\\n\\n        # Find the surplus elements that need to be swapped\\n        surplus1 = []\\n        surplus2 = []\\n\\n        for x in freq:\\n            c1 = freq1.get(x, 0)\\n            c2 = freq2.get(x, 0)\\n            diff = (c1 - c2) // 2\\n            if diff > 0:\\n                surplus1.extend([x] * diff)\\n            elif diff < 0:\\n                surplus2.extend([x] * (-diff))\\n\\n        surplus1.sort()\\n        surplus2.sort(reverse=True)\\n\\n        min_val = min(freq.keys())\\n        cost = 0\\n        for x, y in zip(surplus1, surplus2):\\n            cost += min(2 * min_val, min(x, y))\\n\\n        return cost\\n","compare_result":"1111111111111111111111111111111111111111","title_slug":"rearranging-fruits","has_notes":false,"flag_type":1,"frontend_id":195},{"id":1720500534,"question_id":2689,"lang":"python3","lang_name":"Python3","time":"10\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1754131575,"status":14,"status_display":"Time Limit Exceeded","runtime":"N/A","url":"/submissions/detail/1720500534/","is_pending":"Not Pending","title":"Rearranging Fruits","memory":"N/A","code":"class Solution:\\n    def minCost(self, basket1: List[int], basket2: List[int]) -> int:\\n        freq = {}\\n        all_items = basket1 + basket2\\n        for x in all_items:\\n            freq[x] = freq.get(x, 0) + 1\\n\\n        # If any item occurs odd number of times, not possible\\n        for val in freq.values():\\n            if val % 2 != 0:\\n                return -1\\n\\n        # Build surplus elements\\n        surplus1 = []\\n        surplus2 = []\\n        for x in set(all_items):\\n            c1 = basket1.count(x)\\n            c2 = basket2.count(x)\\n            diff = (c1 - c2) // 2\\n            if diff > 0:\\n                surplus1 += [x] * diff\\n            elif diff < 0:\\n                surplus2 += [x] * (-diff)\\n\\n        surplus1.sort()\\n        surplus2.sort(reverse=True)\\n\\n        min_val = min(all_items)\\n        cost = 0\\n        for x, y in zip(surplus1, surplus2):\\n            cost += min(2 * min_val, min(x, y))\\n        return cost\\n","compare_result":"1111111111111111111111111111111111000000","title_slug":"rearranging-fruits","has_notes":false,"flag_type":1,"frontend_id":194},{"id":1719469363,"question_id":118,"lang":"python3","lang_name":"Python3","time":"10\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1754049993,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1719469363/","is_pending":"Not Pending","title":"Pascal\'s Triangle","memory":"17.9 MB","code":"class Solution:\\n    def generate(self, numRows: int) -> List[List[int]]:\\n        if numRows == 1:\\n            return [[1]]\\n        elif numRows == 2:\\n            return [[1], [1, 1]]\\n\\n        arr = [[1], [1, 1]]\\n\\n        for i in range(2, numRows):\\n            prev = arr[i - 1]\\n            row = [1]\\n            for j in range(1, len(prev)):\\n                row.append(prev[j - 1] + prev[j])\\n            row.append(1)  \\n            arr.append(row)\\n\\n        return arr\\n","compare_result":"111111111111111111111111111111","title_slug":"pascals-triangle","has_notes":false,"flag_type":1,"frontend_id":193},{"id":1718126987,"question_id":934,"lang":"python3","lang_name":"Python3","time":"10\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1753953492,"status":10,"status_display":"Accepted","runtime":"403 ms","url":"/submissions/detail/1718126987/","is_pending":"Not Pending","title":"Bitwise ORs of Subarrays","memory":"44.8 MB","code":"class Solution:\\n    def subarrayBitwiseORs(self, arr: List[int]) -> int:\\n        res = set()\\n        cur = set()\\n        for num in arr:\\n            new_cur = {num}\\n            for prev in cur:\\n                new_cur.add(prev | num)\\n            cur = new_cur\\n            res.update(cur)\\n        return len(res)\\n","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"bitwise-ors-of-subarrays","has_notes":false,"flag_type":1,"frontend_id":192},{"id":1718126031,"question_id":934,"lang":"python3","lang_name":"Python3","time":"10\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1753953438,"status":14,"status_display":"Time Limit Exceeded","runtime":"N/A","url":"/submissions/detail/1718126031/","is_pending":"Not Pending","title":"Bitwise ORs of Subarrays","memory":"N/A","code":"class Solution:\\n    def subarrayBitwiseORs(self, arr: List[int]) -> int:\\n        a = set()\\n        for i in range(len(arr)):\\n            b = arr[i]\\n            a.add(b)\\n            for j in range(i + 1, len(arr)):\\n                b = b | arr[j]\\n                a.add(b)\\n        return len(a)\\n","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111000000000","title_slug":"bitwise-ors-of-subarrays","has_notes":false,"flag_type":1,"frontend_id":191},{"id":1716747020,"question_id":181,"lang":"mysql","lang_name":"MySQL","time":"10\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1753858461,"status":10,"status_display":"Accepted","runtime":"554 ms","url":"/submissions/detail/1716747020/","is_pending":"Not Pending","title":"Employees Earning More Than Their Managers","memory":"0.0B","code":"SELECT ep1.name AS Employee\\nFROM employee AS ep1\\nJOIN employee AS ep2\\n  ON ep1.managerId = ep2.id\\nWHERE ep1.salary > ep2.salary;\\n","compare_result":"11111111111111","title_slug":"employees-earning-more-than-their-managers","has_notes":false,"flag_type":1,"frontend_id":190},{"id":1716666622,"question_id":181,"lang":"mysql","lang_name":"MySQL","time":"10\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1753854249,"status":10,"status_display":"Accepted","runtime":"390 ms","url":"/submissions/detail/1716666622/","is_pending":"Not Pending","title":"Employees Earning More Than Their Managers","memory":"0.0B","code":"# Write your MySQL query statement below\\nselect e1.name as employee\\nfrom employee e1\\njoin employee e2\\non e1.managerId = e2.id\\nwhere e1