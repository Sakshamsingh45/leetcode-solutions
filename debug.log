d List","memory":"N/A","code":"# Definition for singly-linked list.\\n# class ListNode:\\n#     def __init__(self, val=0, next=None):\\n#         self.val = val\\n#         self.next = next\\nclass Solution:\\n    def swapNodes(self, head: Optional[ListNode], k: int) -> Optional[ListNode]:\\n        cur=head\\n        count=0\\n        while cur is not None:\\n            count+=1\\n            cur=cur.next\\n        cur=head\\n        for i in range(1,k):\\n            cur=cur.next\\n        next=cur\\n        for i in range(0,count-2*k+1):\\n            next=next.next\\n        cur.val,next.val=next.val,cur.val\\n        return head","compare_result":"111111011101000011110000011101001101110000111100101100011000101100000011100111101110110110011101100011001111000110101001001100000010","title_slug":"swapping-nodes-in-a-linked-list","has_notes":false,"flag_type":1,"frontend_id":444},{"id":2004842838,"question_id":153,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0month, 1\xc2\xa0week","timestamp":1778955708,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/2004842838/","is_pending":"Not Pending","title":"Find Minimum in Rotated Sorted Array","memory":"19.4 MB","code":"class Solution:\\n    def findMin(self, nums: List[int]) -> int:\\n        left, right = 0, len(nums) - 1\\n\\n        while left < right:\\n            mid = (left + right) // 2\\n\\n            # Minimum is in right half\\n            if nums[mid] > nums[right]:\\n                left = mid + 1\\n            else:\\n                # Minimum is at mid or left half\\n                right = mid\\n\\n        return nums[left]","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"find-minimum-in-rotated-sorted-array","has_notes":false,"flag_type":1,"frontend_id":443},{"id":2004841615,"question_id":153,"lang":"python3","lang_name":"Pyt