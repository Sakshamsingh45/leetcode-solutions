omers.count(\\"Y\\")\\n        min_=0\\n        ope_n={\\"Y\\":0,\\"N\\":0}\\n        clos_e={\\"Y\\":0,\\"N\\":0}\\n        for i in customers:\\n            if i==\\"Y\\":\\n                clos_e[\\"Y\\"]+=1\\n            else:\\n                clos_e[\\"N\\"]+=1\\n        for j , k in enumerate(customers):\\n            min_penalty=ope_n[\\"N\\"]+clos_e[\\"Y\\"]\\n            \\n            if k==\\"N\\":\\n                clos_e[\\"N\\"]-=1\\n                ope_n[\\"N\\"]+=1\\n            else:\\n                clos_e[\\"Y\\"]-=1\\n                ope_n[\\"Y\\"]+=1\\n            \\n            if min_penalty<penalty:\\n                penalty=min_penalty\\n                min_=j\\n\\n        if ope_n[\\"N\\"]<penalty:\\n            min_=len(customers)\\n        return min_\\n\\n","compare_result":"111111111111111111111111111111111111111111","title_slug":"minimum-penalty-for-a-shop","has_notes":false,"flag_type":1,"frontend_id":290},{"id":1865803857,"question_id":2576,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months, 4\xc2\xa0weeks","timestamp":1766752768,"status":10,"status_display":"Accepted","runtime":"186 ms","url":"/submissions/detail/1865803857/","is_pending":"Not Pending","title":"Minimum Penalty for a Shop","memory":"18 MB","code":"class Solution:\\n    def bestClosingTime(self, customers: str) -> int:\\n        penalty = customers.count(\\"Y\\")\\n        min_ = 0\\n\\n        ope_n = {\\"Y\\": 0, \\"N\\": 0}\\n        clos_e = {\\"Y\\": 0, \\"N\\": 0}\\n\\n        # initially, everything is closed\\n        for c in customers:\\n            if c == \\"Y\\":\\n                clos_e[\\"Y\\"] += 1\\n            else:\\n                clos_e[\\"N\\"] += 1\\n\\n        # evaluate closing times 0..n-1\\n        for j, k in enumerate(customers):\\n            # penalty for closing at time j\\n            curr_penalty = ope_n[\\"N\\"] + clos_e[\\"Y\\"]\\n\\n            if curr_penalty < penalty:\\n                penalty = curr_penalty\\n                min_ = j\\n\\n            # now move hour j from closed \xe2\x86\x92 open\\n            if k == \\"N\\":\\n                clos_e[\\"N\\"] -= 1\\n                ope_n[\\"N\\"] += 1\\n            else:\\n                clos_e[\\"Y\\"] -= 1\\n                ope_n[\\"Y\\"] += 1\\n\\n        # check closing at time n\\n        if ope_n[\\"N\\"] < penalty:\\n            min_ = len(customers)\\n\\n        return min_","compare_result":"111111111111111111111111111111111111111111","title_slug":"minimum-penalty-for-a-shop","has_notes":false,"flag_type":1,"frontend_id":289},{"id":1865803018,"question_id":2576,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months, 4\xc2\xa0weeks","timestamp":1766752689,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1865803018/","is_pending":"Not Pending","title":"Minimum Penalty for a Shop","memory":"N/A","code":"class Solution:\\n    def bestClosingTime(self, customers: str) -> int:\\n        penalty=len(customers)\\n        min_=0\\n        ope_n={\\"Y\\":0,\\"N\\":0}\\n        clos_e={\\"Y\\":0,\\"N\\":0}\\n        for i in customers:\\n            if i==\\"Y\\":\\n                clos_e[\\"N\\"]+=1\\n            else:\\n                clos_e[\\"Y\\"]+=1\\n        for j , k in enumerate(customers):\\n            if k==\\"N\\":\\n                clos_e[\\"N\\"]-=1\\n                ope_n[\\"N\\"]+=1\\n            else:\\n                clos_e[\\"Y\\"]-=1\\n                ope_n[\\"Y\\"]+=1\\n            \\n            min_penalty=ope_n[\\"N\\"]+clos_e[\\"Y\\"]\\n            if min_penalty<penalty:\\n                penalty=min_penalty\\n                min_=j+1\\n        return min_\\n\\n","compare_result":"111111111101011111111111111111111111111111","title_slug":"minimum-penalty-for-a-shop","has_notes":false,"flag_type":1,"frontend_id":288},{"id":1865799909,"question_id":2576,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months, 4\xc2\xa0weeks","timestamp":17667523