lt=10\\n        current=9\\n        for i in range(2,n+1):\\n            current=current*(10-(i-1))\\n            result+=current\\n        return result","compare_result":"111111111","title_slug":"count-numbers-with-unique-digits","has_notes":false,"flag_type":1,"frontend_id":469},{"id":2020403193,"question_id":2,"lang":"python3","lang_name":"Python3","time":"3\xc2\xa0weeks, 2\xc2\xa0days","timestamp":1780418678,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/2020403193/","is_pending":"Not Pending","title":"Add Two Numbers","memory":"19.3 MB","code":"# Definition for singly-linked list.\\n# class ListNode:\\n#     def __init__(self, val=0, next=None):\\n#         self.val = val\\n#         self.next = next\\nclass Solution:\\n    def addTwoNumbers(self, l1: Optional[ListNode], l2: Optional[ListNode]) -> Optional[ListNode]:\\n        carry=0\\n        head=ListNode(0)\\n        cur=head\\n        while l1!=None or l2!=None or carry!=0:\\n            l1val=l1.val if l1 else 0\\n            l2val=l2.val if l2 else 0\\n            cur.next=ListNode((l1val+l2val+carry)%10)\\n            carry=(l1val+l2val+carry)//10\\n            cur=cur.next\\n            l1=l1.next if l1 else None\\n            l2=l2.next if l2 else None\\n        return head.next","compare_result":"","title_slug":"add-two-numbers","has_notes":false,"flag_type":1,"frontend_id":468},{"id":2018646317,"question_id":2248,"lang":"python3","lang_name":"Python3","time":"3\xc2\xa0weeks, 4\xc2\xa0days","timestamp":1780285361,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/2018646317/","is_pending":"Not Pending","title":"Minimum Cost of Buying Candies With Discount","memory":"19.2 MB","code":"class Solution:\\n    def minimumCost(self, cost: List[int]) -> int:\\n        cost.sort()\\n        count=0\\n        left=len(cost)%3\\n        i=1+left\\n        while i <len(cost)-1:\\n            count+=cost[i]+cost[i+1]\\n            i+=3\\n        for i in range(left):\\n            count+=cost[i]\\n        return count","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"minimum-cost-of-buying-candies-with-discount","has_notes":false,"flag_type":1,"frontend_id":467},{"id":2017630206,"question_id":2245,"lang":"python3","lang_name":"Python3","time":"3\xc2\xa0weeks, 5\xc2\xa0days","timestamp":1780186117,"status":10,"status_display":"Accepted","runtime":"64 ms","url":"/submissions/detail/2017630206/","is_pending":"Not Pending","title":"Destroying Asteroids","memory":"34.1 MB","code":"class Solution:\\n    def asteroidsDestroyed(self, mass: int, asteroids: List[int]) -> bool:\\n        asteroids.sort()\\n        for i in asteroids:\\n            if i>mass:\\n                return False\\n            mass+=i\\n        return True","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"destroying-asteroids","has_notes":false,"flag_type":1,"frontend_id":466},{"id":2016827082,"question_id":2903,"lang":"python3","lang_name":"Python3","time":"3\xc2\xa0weeks, 6\xc2\xa0days","timestamp":1780102491,"status":10,"status_display":"Accepted","runtime":"13 ms","url":"/submissions/detail/2016827082/","is_pending":"Not Pending","title":"Insert Greatest Common Divisors in Linked List","memory":"22.7 MB","code":"# Definition for singly-linked list.\\n# class ListNode:\\n#     def __init__(self, val=0, next=None):\\n#         self.val = val\\n#         self.next = next\\nclass Solution:\\n    def insertGreatestCommonDivisors(self, head: Optional[ListNode]) -> Optional[ListNode]:\\n        def gof(a,b):\\n            while b:\\n                a,b=b,a%b\\n            return a\\n        cur=head\\n        while cur and cur.next:\\n            node=ListNode(gof(cur.val,cur.next.val),cur.next)\\n            cur.next=node\\n            cur=node.next\\n        return head","compare_result":"","title_slug":"insert-greatest-common-divisors-in-linked-list","has_notes":false,"flag_type":1,"frontend_id":465},{"id":2016249320,"question_id":3606,"lang":"python3","lang_name":"Python3","time":"4\xc2\xa0weeks","timestamp":1780044395,"status":10,"status_display":"Accepted","runtime":"3 ms","url":"/submissions/detail/2016249320/","is_pending":"Not Pending","title":"Minimum Element After Replacement With Digit Sum","memory":"19.4 MB","code":"class Solution:\\n    def minElement(self, nums: List[int]) -> int:\\n        m=float(\\"inf\\")\\n        for i in nums:\\n            b=0\\n            while i!=0:\\n                digit=i%10\\n                b+=digit\\n                i//=10\\n            m=b if m>b else m\\n        return m\\n","compare_result":"","title_slug":"minimum-element-after-replacement-with-digit-sum","has_notes":false,"flag_type":1,"frontend_id":464},{"id":2015147284,"question_id":148,"lang":"python3","lang_name":"Python3","time":"4\xc2\xa0weeks, 1\xc2\xa0day","timestamp":1779946324,"status":10,"status_display":"Accepted","runtime":"27 ms","url":"/submissions/detail/2015147284/","is_pending":"Not Pending","title":"Sort List","memory":"40.8 MB","code":"# Definition for singly-linked list.\\n# class ListNode:\\n#     def __init__(self, val=0, next=None):\\n#         self.val = val\\n#         self.next = next\\nclass Solution:\\n    def sortList(self, head: Optional[ListNode]) -> Optional[ListNode]:\\n        nu=[]\\n        cur=head\\n        while cur is not None:\\n            nu.append(cur.val)\\n            cur=cur.next\\n        nu.sort()\\n        cur=head\\n        i=0\\n        while cur is not None:\\n            cur.val=nu[i]\\n            cur=cur.next\\n            i+=1\\n        return head","compare_result":"111111111111111111111111111111","title_slug":"sort-list","has_notes":false,"flag_type":1,"frontend_id":463},{"id":2014600759,"question_id":3405,"lang":"python3","lang_name":"Python3","time":"4\xc2\xa0weeks, 1\xc2\xa0day","timestamp":1779888049,"status":10,"status_display":"Accepted","runtime":"336 ms","url":"/submissions/detail/2014600759/","is_pending":"Not Pending","title":"Count the Number of Special Characters II","memory":"21.6 MB","code":"class Solution:\\n    def numberOfSpecialChars(self, word: str) -> int:\\n        freq={}\\n        r=set()\\n        for i,j in enumerate(word):\\n            if j.islower() and j not in r:\\n                freq[j]=i\\n                if j.upper() in freq and freq[j.upper()]<freq[j]:\\n                    del freq[j]\\n                    del freq[j.upper()]\\n                    r.add(j)\\n                    r.add(j.upper())\\n            elif j.isupper() and j not in r:\\n                if j not in freq:\\n                    freq[j]=i\\n        count=0\\n        for k in freq:\\n            if k.islower() and k.upper() in freq:\\n                count+=1\\n        return count","compare_result":"","title_slug":"count-the-number-of-special-characters-ii","has_notes":false,"flag_type":1,"frontend_id":462},{"id":2013166849,"question_id":3408,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0month","timestamp":1779766783,"status":10,"status_display":"Accepted","runtime":"4 ms","url":"/submissions/detail/2013166849/","is_pending":"Not Pending","title":"Count the Number of Special Characters I","memory":"19.4 MB","code":"class Solution:\\n    def numberOfSpecialChars(self, word: str) -> int:\\n        count=0\\n        word=set(word)\\n        for i in word:\\n            if i.isupper() and i.lower() in word:\\n                count+=1\\n            elif i.islower() and i.upper() in word:\\n                count+=1\\n        return count//2","compare_result":"","title_slug":"count-the-number-of-special-characters-i","has_notes":false,"flag_type":1,"frontend_id":461},{"id":2013162480,"question_id":3408,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0month