lt":"","title_slug":"maximum-number-of-jumps-to-reach-the-last-index","has_notes":false,"flag_type":1,"frontend_id":433},{"id":1998552768,"question_id":160,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0month, 2\xc2\xa0weeks","timestamp":1778302666,"status":10,"status_display":"Accepted","runtime":"131 ms","url":"/submissions/detail/1998552768/","is_pending":"Not Pending","title":"Intersection of Two Linked Lists","memory":"39.4 MB","code":"# Definition for singly-linked list.\\n# class ListNode:\\n#     def __init__(self, x):\\n#         self.val = x\\n#         self.next = None\\n\\nclass Solution:\\n    def getIntersectionNode(self, headA: ListNode, headB: ListNode) -> Optional[ListNode]:\\n        val=set()\\n        temp=headA\\n        while temp!=None:\\n            val.add(id(temp))\\n            temp=temp.next\\n        temp=headB\\n        while temp!=None:\\n            if id(temp) in val:\\n                return temp\\n            temp=temp.next\\n        return None\\n        \\n        ","compare_result":"11111111111111111111111111111111111111111","title_slug":"intersection-of-two-linked-lists","has_notes":false,"flag_type":1,"frontend_id":432},{"id":1998549654,"question_id":445,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0month, 2\xc2\xa0weeks","timestamp":1778302293,"status":10,"status_display":"Accepted","runtime":"3 ms","url":"/submissions/detail/1998549654/","is_pending":"Not Pending","title":"Add Two Numbers II","memory":"19.2 MB","code":"# Definition for singly-linked list.\\n# class ListNode:\\n#     def __init__(self, val=0, next=None):\\n#         self.val = val\\n#         self.next = next\\nclass Solution:\\n    def addTwoNumbers(self, l1: Optional[ListNode], l2: Optional[ListNode]) -> Optional[ListNode]:\\n        temp=l1\\n        c1=c2=0\\n        while temp!=None:\\n            c1=c1*10+temp.val\\n            temp=temp.next\\n        temp=l2\\n        while temp!=None:\\n            c2=c2*10+temp.val\\n            temp=temp.next\\n        ans=c1+c2\\n        head=cur=ListNode(0)\\n        for i in str(ans):\\n            cur.next=ListNode(int(i))\\n            cur=cur.next\\n\\n        return head.next\\n\\n        ","compare_result":"","title_slug":"add-two-numbers-ii","has_notes":false,"flag_type":1,"frontend_id":431},{"id":1998389714,"question_id":234,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0month, 2\xc2\xa0weeks","timestamp":1778268733,"status":10,"status_display":"Accepted","runtime":"99 ms","url":"/submissions/detail/1998389714/","is_pending":"Not Pending","title":"Palindrome Linked List","memory":"54.1 MB","code":"# Definition for singly-linked list.\\n# class ListNode:\\n#     def __init__(self, val=0, next=None):\\n#         self.val = val\\n#         self.next = next\\nclass Solution:\\n    def isPalindrome(self, head: Optional[ListNode]) -> bool:\\n        cur=head\\n        s=\\"\\"\\n        while cur!=None:\\n            s+=str(cur.val)\\n            cur=cur.next\\n        return s==s[::-1]\\n","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"palindrome-linked-list","has_notes":false,"flag_type":1,"frontend_id":430},{"id":1997886252,"question_id":66,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0month, 2\xc2\xa0weeks","timestamp":1778218605,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1997886252/","is_pending":"Not Pending","title":"Plus One","memory":"19.4 MB","code":"class Solution:\\n    def plusOne(self, digits: List[int]) -> List[int]:\\n        carry=1\\n        for i in range(-1,-len(digits)-1,-1):\\n            s=digits[i]+carry\\n            carry=0 if s<10 else 1\\n            d=s%10\\n            digits[i]=d\\n        if carry:\\n            digits.insert(0,carry)\\n        return digits","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"plus-one","has_notes":false,"flag_type":1,"frontend_id":429},{"id":1997687902,"question_id":328,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0month, 2\xc2\xa0weeks","timestamp":1778185280,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1997687902/","is_pending":"Not Pending","title":"Odd Even Linked List","memory":"21.2 MB","code":"# Definition for singly-linked list.\\n# class ListNode:\\n#     def __init__(self, val=0, next=None):\\n#         self.val = val\\n#         self.next = next\\nclass Solution:\\n    def oddEvenList(self, head: Optional[ListNode]) -> Optional[ListNode]:\\n        cur=head\\n        if cur!=None:\\n            od=cur.next\\n        else:\\n            od=None\\n        while od!=None and od.next!=None:\\n            temp=od.next\\n            cur.next,temp.next,od.next=temp,cur.next,temp.next\\n            od=od.next\\n            cur=cur.next\\n        return head\\n\\n","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"odd-even-linked-list","has_notes":false,"flag_type":1,"frontend_id":428},{"id":1996783957,"question_id":1972,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0month, 2\xc2\xa0weeks","timestamp":1778088525,"status":10,"status_display":"Accepted","runtime":"159 ms","url":"/submissions/detail/1996783957/","is_pending":"Not Pending","title":"Rotating the Box","memory":"52.1 MB","code":"class Solution:\\n    def rotateTheBox(self, boxGrid: List[List[str]]) -> List[List[str]]:\\n        for k in boxGrid:\\n            j=i=0\\n            while i<len(k) and j<len(k):\\n                if k[j]==\\"*\\":\\n                    i=j\\n                    i+=1\\n                    j+=1\\n                    continue\\n                if k[j]==\\"#\\":\\n                    j+=1\\n                    continue\\n                if k[j]==k[i]:\\n                    j+=1\\n                    i+=1\\n                    continue\\n                if k[j]==\\".\\" and k[i]==\\"#\\":\\n                    k[j],k[i]=\\"#\\",\\".\\"\\n                    i+=1\\n                    j+=1\\n        return [list(a) for a in zip(*boxGrid[::-1])]\\n                ","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"rotating-the-box","has_notes":false,"flag_type":1,"frontend_id":427},{"id":1995617071,"question_id":61,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1777968177,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1995617071/","is_pending":"Not Pending","title":"Rotate List","memory":"18.9 MB","code":"# Definition for singly-linked list.\\n# class ListNode:\\n#     def __init__(self, val=0, next=None):\\n#         self.val = val\\n#         self.next = next\\nclass Solution:\\n    def rotateRight(self, head: Optional[ListNode], k: int) -> Optional[ListNode]:\\n        if not head or not head.next or k == 0:\\n            return head\\n        count=0\\n        cur=head\\n        while cur is not None:\\n            count+=1\\n            cur=cur.next\\n        k%=count\\n        cur=fast=head\\n        if k==0:\\n            return head\\n        for i in range(k):\\n            fast=fast.next\\n        while fast.next is not None:\\n            cur=cur.next\\n            fast=fast.next\\n        next=cur.next\\n        fast.next=head\\n        cur.next=None\\n        head=next\\n        return head\\n","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"rotate-list","has_notes":false,"flag_type":1,"frontend_id":426},{"id":1995616336,"question_id":61,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1777968112,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1995616336/","is_pending":"Not Pending","title":"Rotate List","memory":"N/A","code":"# Definition for singly-linked list.\\n# class ListNode:\\n#     def __init__(self, val=0, next=None):\\n#         self.val = val\\n#         self.next = next\\nclass Solution:\\n    def rotateRight(self, head: Optional[ListNode], k: int) -> Optional[ListNode]:\\n        if not head or not head.next or k == 0:\\n            return head\\n        count=0\\n        cur=head\\n        while cur is not None:\\n            count+=1\\n            cur=cur.next\\n        k%=count\\n        cur=fast=head\\n        for i in range(k):\\n            fast=fast.next\\n        while fast.next is not None:\\n            cur=cur.next\\n            fast=fast.next\\n        next=cur.next\\n        fast.next=head\\n        cur.next=None\\n        head=next\\n        return head\\n","compare_result":"1111111110111111011111110111101101111111101101111111101111111111111111111111111111111111111111110111011111110111011011111111011111111111111111111111111111101111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"rotate-list","has_notes":false,"flag_type":1,"frontend_id":425},{"id":1995110471,"question_id":48,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0month, 3\xc2\xa0weeks","timestamp":1777912300,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1995110471/","is_pending":"Not Pending","title":"Rotate Image","memory":"19.1 MB","code":"class Solution:\\n    def rotate(self, matrix: List[List[int]]) -> None:\\n        \\"\\"\\"\\n        Do not return anything, modify matrix in-place instead.\\n        \\"\\"\\"\\n        matrix[:]=[list(s) for s in zip(*matrix[::-1])]","compare_result":"111111111111111111111","title_slug":"rotate-image","has_notes":false,"flag_type":1,"frontend_id":424},{"id":1994086618,"question_