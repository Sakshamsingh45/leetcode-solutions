0: \\"L\\",60: \\"LX\\",70: \\"LXX\\",80: \\"LXXX\\",90: \\"XC\\",100: \\"C\\",200: \\"CC\\",300: \\"CCC\\",400: \\"CD\\",500: \\"D\\",600: \\"DC\\",700: \\"DCC\\",800: \\"DCCC\\",900: \\"CM\\",1000: \\"M\\",2000: \\"MM\\",3000: \\"MMM\\"}\\n\\n        po=0\\n        ans=\\"\\"\\n        while num!=0:\\n            if num%10==0:\\n                pass\\n            else:\\n                ans=ir[(num%10)*(10**po)]+ans\\n            num//=10\\n            po+=1\\n        return ans","compare_result":"","title_slug":"integer-to-roman","has_notes":false,"flag_type":1,"frontend_id":494},{"id":2043949597,"question_id":6,"lang":"python3","lang_name":"Python3","time":"2\xc2\xa0days, 8\xc2\xa0hours","timestamp":1782262208,"status":10,"status_display":"Accepted","runtime":"7 ms","url":"/submissions/detail/2043949597/","is_pending":"Not Pending","title":"Zigzag Conversion","memory":"19.3 MB","code":"class Solution:\\n    def convert(self, s: str, numRows: int) -> str:\\n        if numRows==1:\\n            return s\\n        l=[[] for _ in range(numRows)]\\n        count=0\\n        dir=1\\n        for i in s:\\n            l[count].append(i)\\n            if count==0:\\n                dir=1\\n            elif count==len(l)-1:\\n                dir=-1\\n            count+=dir\\n        ans=\\"\\"\\n        for i in l:\\n            ans+=\\"\\".join(i)\\n        return ans","compare_result":"","title_slug":"zigzag-conversion","has_notes":false,"flag_type":1,"frontend_id":493},{"id":2043462499,"question_id":17,"lang":"python3","lang_name":"Python3","time":"2\xc2\xa0days, 19\xc2\xa0hours","timestamp":1782223191,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/2043462499/","is_pending":"Not Pending","title":"Letter Combinations of a Phone Number","memory":"19.3 MB","code":"class Solution:\\n    def letterCombinations(self, digits: str) -> List[str]:\\n        alpha={\\n            \\"2\\":\\"abc\\",\\n            \\"3\\":\\"def\\",\\n            \\"4\\":\\"ghi\\",\\n            \\"5\\":\\"jkl\\",\\n            \\"6\\":\\"mno\\",\\n            \\"7\\":\\"pqrs\\",\\n            \\"8\\":\\"tvu\\",\\n            \\"9\\":\\"wxyz\\"\\n        }\\n        ans=[]\\n        for i in alpha[digits[0]]:\\n            cur=i\\n            if len(digits)>1:\\n                for j in alpha[digits[1]]:\\n                    cur2=cur+j\\n                    if len(digits)>2:\\n                        for k in alpha[digits[2]]:\\n                            cur3=cur2+k\\n                            if len(digits)>3:\\n                                for l in alpha[digits[3]]:\\n                                    cur4=cur3+l\\n                                    ans.append(cur4)\\n                            if len(digits)==3:\\n                                ans.append(cur3)\\n                    if len(digits)==2:\\n                        ans.append(cur2)\\n            if len(digits)==1:\\n                ans.append(cur)\\n        return ans \\n                        ","compare_result":"111111111111111111111111","title_slug":"letter-combinations-of-a-phone-number","has_notes":false,"flag_type":1,"frontend_id":492},{"id":2041499648,"question_id":1297,"lang":"python3","lang_name":"Python3","time":"4\xc2\xa0days, 7\xc2\xa0hours","timestamp":1782093021,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/2041499648/","is_pending":"Not Pending","title":"Maximum Number of Balloons","memory":"19.3 MB","code":"class Solution:\\n    def maxNumberOfBalloons(self, text: str) -> int:\\n        text.lower()\\n        freq={\\"b\\":0,\\"a\\":0,\\"l\\":0,\\"o\\":0,\\"n\\":0}\\n        for i in text:\\n            if i in freq:\\n                freq[i]+=1\\n        return min(freq[\\"b\\"],freq[\\"a\\"],freq[\\"l\\"]//2,freq[\\"o\\"]//2,freq[\\"n\\"])","compare_result":"1111111111111111111111111111","title_slug":"maximum-number-of-balloons","has_notes":false,"flag_type":1,"frontend_id":491},{"id":2041300918,"question_id":1961,"lang":"python3","lang_name":"Python3","time":"4\xc2\xa0days, 14\xc2\xa0hours","timestamp":1782065658,"status":10,"status_display":"Accepted","runtime":"61 ms","url":"/submissions/detail/2041300918/","is_pending":"Not Pending","title":"Maximum Ice Cream Bars","memory":"31.1 MB","code":"class Solution:\\n    def maxIceCream(self, costs: List[int], coins: int) -> int:\\n        freq=[0]*(max(costs)+1)\\n        sort=[]\\n        count=0\\n        for i in costs:\\n            freq[i]+=1\\n        for i in range(len(freq)):\\n            while freq[i]>0 and coins>=i:\\n                count+=1\\n                coins-=i\\n                freq[i]-=1\\n        return count","compare_result":"111111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-ice-cream-bars","has_notes":false,"flag_type":1,"frontend_id":490},{"id":2040342962,"question_id":1961,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0days, 8\xc2\xa0hours","timestamp":1782002890,"status":10,"status_display":"Accepted","runtime":"79 ms","url":"/submissions/detail/2040342962/","is_pending":"Not Pending","title":"Maximum Ice Cream Bars","memory":"32.1 MB","code":"class Solution:\\n    def maxIceCream(self, costs: List[int], coins: int) -> int:\\n        costs.sort()\\n        count=0\\n        for i in costs:\\n            if i<=coins:\\n                count+=1\\n                coins-=i\\n            else:\\n                return count\\n        return count","compare_result":"111111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-ice-cream-bars","has_notes":false,"flag_type":1,"frontend_id":489},{"id":2039750631,"question_id":16,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0days, 20\xc2\xa0hours","timestamp":1781958518,"status":10,"status_display":"Accepted","runtime":"391 ms","url":"/submissions/detail/2039750631/","is_pending":"Not Pending","title":"3Sum Closest","memory":"19.2 MB","code":"class Solution:\\n    def threeSumClosest(self, nums: List[int], target: int) -> int:\\n        nums.sort()\\n        close=sum(nums[:3])\\n        for i in range(len(nums)):\\n            st,lt=i+1,len(nums)-1\\n            while st<lt:\\n                n=nums[i]+nums[st]+nums[lt]\\n                if abs(target-n)<abs(target-close):\\n                    close=n\\n                if n<target:\\n                    st+=1\\n                elif n>target:\\n                    lt-=1\\n                else:\\n                    return target\\n        return close\\n                ","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"3sum-closest","has_notes":false,"flag_type":1,"frontend_id":488},{"id":2038108775,"question_id":1833,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0week","timestamp":1781832051,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/2038108775/","is_pending":"Not Pending","title":"Find the Highest Altitude","memory":"19.3 MB","code":"class Solution:\\n    def largestAltitude(self, gain: List[int]) -> int:\\n        prev=alt=0\\n        for i in gain:\\n            prev=i+prev\\n            alt=prev if alt<prev else alt\\n        return alt","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"find-the-highest-altitude","has_notes":false,"flag_type":1,"frontend_id":487},{"id":2037872598,"question_id":1446,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0week","timestamp":1781804060,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/2037872598/","is_pending":"Not Pending","title":"Angle Between Hands of a Clock","memory":"19.5 MB","code":"class Solution:\\n    def angleClock(self, hour: int, minutes: int) -> float:\\n        if minutes:\\n            h=(((hour%12)*5)+(5/(60/minutes)))\\n        else:\\n            h=((hour%12)*5)\\n        angle=abs((minutes-h)*6)\\n        return min(angle,360-angle)","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"angle-between-hands-of-a-clock","has_notes":false,"flag_type":1,"frontend_id":486},{"id":2036146836,"question_id":143,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0week, 2\xc2\xa0days","timestamp":1781686580,"status":10,"status_display":"Accepted","runtime":"1 ms","url":"/submissions/detail/2036146836/","is_pending":"Not Pending","title":"Reorder List","memory":"27.8 MB","code":"# Definition for singly-linked list.\\n# class ListNode:\\n#     def __init__(self, val=0, next=None):\\n#         self.val = val\\n#         self.next = next\\nclass Solution:\\n    def reorderList(self, head: Optional[ListNode]) -> None:\\n        \\"\\"\\"\\n        Do not return anything, modify head in-place instead.\\n        \\"\\"\\"\\n        slow=fast=head\\n        if not head or not head.next:\\n            return\\n        while fast is not None and fast.next is not None:\\n            fast=fast.next.next\\n            slow=slow.next\\n        mid=slow.next\\n        slow.next=None\\n        prev=None\\n        while mid!=None:\\n            next=mid.next\\n            mid.next=prev\\n            prev=mid\\n            mid=next\\n        cur=head\\n        while cur and prev:\\n            next1=cur.next\\n            next2=prev.next\\n            cur.next=prev\\n            prev.next=next1\\n            prev=next2\\n            cur=next1","compare_result":"111111111111","title_slug":"reorder-list","has_notes":false,"flag_type":1,"frontend_id":485},{"id":2034807178,"question_id":3931,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0week, 3\xc2\xa0days","timestamp":1781593382,"status":10,"status_display":"Accepted","runtime":"44 ms","url":"/submissions/detail/2034807178/","is_pending":"Not Pending","title":"Process String with Special Operations I","memory":"28.5 MB","code":"class Solution:\\n    def processStr(self, s: str) -> str:\\n        a=[]\\n        count=0\\n        for i in s:\\n            if i.isalpha():\\n                a.append(i)\\n            elif i==\\"#\\":\\n                a=a*2\\n            elif i==\\"*\\" and a:\\n                a.pop()\\n            elif i==\\"%\\":\\n                a=a[::-1]\\n        return \\"\\".join(a)","compare_result":"","title_slug":"process-string-with-special-operations-i","has_notes":false,"flag_type":1,"frontend_id":484},{"id":2033420301,"question_id":2216,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0week, 4\xc2\xa0days","timestamp":1781497885,"status":10,"status_display":"Accepted","runtime":"109 ms","url":"/submissions/detail/2033420301/","is_pending":"Not Pending","title":"Delete the Middle Node of a Linked List","memory":"62 MB","code":"# Definition for singly-linked list.\\n# class ListNode:\\n#     def __init__(self, val=0, next=None):\\n#         self.val = val\\n#         self.next = next\\nclass Solution:\\n    def deleteMiddle(self, head: Optional[ListNode]) -> Optional[ListNode]:\\n        dummy=ListNode(None,head)\\n        count=0\\n        prev=dummy\\n        cur=fast=head\\n        while fast and fast.next:\\n            prev=prev.next\\n            cur=cur.next\\n            fast=fast.next.next\\n            count+=1\\n        prev.next=cur.next\\n        cur.next=None\\n        return dummy.next","compare_result":"1111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"delete-the-middle-node-of-a-linked-list","has_notes":false,"flag_type":1,"frontend_id":483},{"id":2032529457,"question_id":2236,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0week, 5\xc2\xa0days","timestamp":1781419623,"status":10,"status_display":"Accepted","runtime":"51 ms","url":"/submissions/detail/2032529457/","is_pending":"Not Pending","title":"Maximum Twin Sum of a Linked List","memory":"50.6 MB","code":"# Definition for singly-linked list.\\n# class ListNode:\\n#     def __init__(self, val=0, next=None):\\n#         self.val = val\\n#         self.next = next\\nclass Solution:\\n    def pairSum(self, head: Optional[ListNode]) -> int:\\n        cur=fast=head\\n        count=0\\n        mx=float(\\"-inf\\")\\n        while fast and fast.next:\\n            cur=cur.next\\n            fast=fast.next.next\\n            count+=1\\n        fast=cur\\n        cur=head\\n        prev=None\\n        while fast :\\n            temp=fast.next\\n            fast.next=prev\\n            prev=fast\\n            fast=temp\\n        l1=head\\n        l2=prev\\n        for i in range(count):\\n            val=l1.val+l2.val\\n            mx=val if val>mx else mx\\n            l1=l1.next\\n            l2=l2.next\\n        return mx\\n","compare_result":"1111111111111111111111111111111111111111111111","title_slug":"maximum-twin-sum-of-a-linked-list","has_notes":false,"flag_type":1,"frontend_id":482},{"id":2031737364,"question_id":4216,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0week, 5\xc2\xa0days","timestamp":1781351696,"status":10,"status_display":"Accepted","runtime":"6 ms","url":"/submissions/detail/2031737364/","is_pending":"Not Pending","title":"Weighted Word Mapping","memory":"19.3 MB","code":"class Solution:\\n    def mapWordWeights(self, words: List[str], weights: List[int]) -> str:\\n        ans=\\"\\"\\n        for i in words:\\n            count=0\\n            for j in i:\\n                count+=weights[ord(j)-97]\\n            ans+=chr(122-count%26)\\n        return ans\\n         ","compare_result":"","title_slug":"weighted-word-mapping","has_notes":false,"flag_type":1,"frontend_id":481},{"id":2030534245,"question_id":203,"lang":"python3","lang_name":"Python3","time":"2\xc2\xa0weeks","timestamp":1781249221,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/2030534245/","is_pending":"Not Pending","title":"Remove Linked List Elements","memory":"22.3 MB","code":"# Definition for singly-linked list.\\n# class ListNode:\\n#     def __init__(self, val=0, next=None):\\n#         self.val = val\\n#         self.next = next\\nclass Solution:\\n    def removeElements(self, head: Optional[ListNode], val: int) -> Optional[ListNode]:\\n        dummy=prev=ListNode(None,head)\\n        cur=head\\n        while cur is not None:\\n            if cur.val==val:\\n                prev.next=cur.next\\n            else:\\n                prev=cur\\n            cur=cur.next\\n        return dummy.next","compare_result":"111111111111111111111111111111111111111111111111111111111111111111","title_slug":"remove-linked-list-elements","has_notes":false,"flag_type":1,"frontend_id":480},{"id":2029665996,"question_id":397,"lang":"python3","lang_name":"Python3","time":"2\xc2\xa0weeks","timestamp":1781176699,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/2029665996/","is_pending":"Not Pending","title":"Integer Replacement","memory":"19.3 MB","code":"class Solution:\\n    def integerReplacement(self, n: int) -> int:\\n        count=0\\n        while n!=1:\\n            if n%2==0:\\n                n=n//2\\n            else:\\n                if n==3 or not((n>>1)&1):\\n                    n-=1\\n                else:\\n                    n+=1\\n            count+=1\\n        return count","compare_result":"11111111111111111111111111111111111111111111111","title_slug":"integer-replacement","has_notes":false,"flag_type":1,"frontend_id":479}],"has_next":true,"last_key":""}'
