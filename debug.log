rontend_id":137},{"id":1675763630,"question_id":2150,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year","timestamp":1750836075,"status":10,"status_display":"Accepted","runtime":"1975 ms","url":"/submissions/detail/1675763630/","is_pending":"Not Pending","title":"Kth Smallest Product of Two Sorted Arrays","memory":"25.5 MB","code":"class Solution:\\n    def kthSmallestProduct(\\n        self, nums1: List[int], nums2: List[int], k: int\\n    ) -> int:\\n        n1, n2 = len(nums1), len(nums2)\\n        pos1, pos2 = 0, 0\\n        while pos1 < n1 and nums1[pos1] < 0:\\n            pos1 += 1\\n        while pos2 < n2 and nums2[pos2] < 0:\\n            pos2 += 1\\n        left, right = int(-1e10), int(1e10)\\n        while left <= right:\\n            mid = (left + right) // 2\\n            count = 0\\n            i1, i2 = 0, pos2 - 1\\n            while i1 < pos1 and i2 >= 0:\\n                if nums1[i1] * nums2[i2] > mid:\\n                    i1 += 1\\n                else:\\n                    count += pos1 - i1\\n                    i2 -= 1\\n            i1, i2 = pos1, n2 - 1\\n            while i1 < n1 and i2 >= pos2:\\n                if nums1[i1] * nums2[i2] > mid:\\n                    i2 -= 1\\n                else:\\n                    count += i2 - pos2 + 1\\n                    i1 += 1\\n            i1, i2 = 0, pos2\\n            while i1 < pos1 and i2 < n2:\\n                if nums1[i1] * nums2[i2] > mid:\\n                    i2 += 1\\n                else:\\n                    count += n2 - i2\\n                    i1 += 1\\n            i1, i2 = pos1, 0\\n            while i1 < n1 and i2 < pos2:\\n                if nums1[i1] * nums2[i2] > mid:\\n                    i1 += 1\\n                else:\\n                    count += n1 - i1\\n                    i2 += 1\\n            if count < k:\\n                left = mid + 1\\n            else:\\n                right = mid - 1\\n        return left","compare_result":"11111111111111111111