s)):\\n            if(a==1):\\n                break\\n            for j in range(i+1,len(nums)):\\n                if((nums[i]+nums[j])==target):\\n                    self=[i,j]\\n                    a=1\\n                    return self\\n                    \\n\\n\\n        ","compare_result":"111111111111111111111111111111111111111111111111111111111111111","title_slug":"two-sum","has_notes":null,"flag_type":1,"frontend_id":296},{"id":1875713840,"question_id":2089,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months, 2\xc2\xa0weeks","timestamp":1767641482,"status":10,"status_display":"Accepted","runtime":"84 ms","url":"/submissions/detail/1875713840/","is_pending":"Not Pending","title":"Maximum Matrix Sum","memory":"27 MB","code":"class Solution:\\n    def maxMatrixSum(self, matrix: List[List[int]]) -> int:\\n        su=0\\n        count=0\\n        minarg=float(\\"inf\\")\\n        for i in matrix:\\n            for j in i:\\n                if j<0:\\n                    count+=1\\n                minarg=min(minarg,abs(j))\\n                su+=abs(j)\\n        if count%2!=0:\\n            su-=2*minarg\\n        return su\\n","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"maximum-matrix-sum","has_notes":false,"flag_type":1,"frontend_id":295},{"id":1874653239,"question_id":1284,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1767560712,"status":10,"status_display":"Accepted","runtime":"211 ms","url":"/submissions/detail/1874653239/","is_pending":"Not Pending","title":"Four Divisors","memory":"18.7 MB","code":"class Solution:\\n    def sumFourDivisors(self, nums: List[int]) -> int:\\n        finalsum = 0\\n\\n        for i in nums:\\n            if i <= 5:\\n                continue\\n\\n            count = 2       \\n            sum = i + 1\\n\\n            left = 2\\n            while left * left <= i:\\n                if i % left == 0:\\n                    right = i // left\\n\\n                    if left == right:\\n                        count += 1\\n                        sum += left\\n                    else:\\n                        count += 2\\n                        sum += left + right\\n\\n                if count > 4:\\n                    sum = 0\\n                    break\\n\\n                left += 1\\n\\n            if count == 4:\\n                finalsum += sum\\n\\n        return finalsum","compare_result":"111111111111111111","title_slug":"four-divisors","has_notes":false,"flag_type":1,"frontend_id":294},{"id":1874647447,"question_id":1284,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1767560019,"status":14,"status_display":"Time Limit Exceeded","runtime":"N/A","url":"/submissions/detail/1874647447/","is_pending":"Not Pending","title":"Four Divisors","memory":"N/A","code":"class Solution:\\n    def sumFourDivisors(self, nums: List[int]) -> int:\\n        finalsum=0\\n        for i in nums:\\n            if i<=5:\\n                continue\\n            count=2\\n            sum=i+1\\n            left,right=2,i-1\\n            while left<right:\\n                if i%left==0:\\n                    count+=1\\n                    sum+=left\\n                if i%right==0:\\n                    count+=1\\n                    sum+=right\\n                right-=1\\n                left+=1\\n                if count>4:\\n                    sum=0\\n                    break\\n            if count<4:\\n                sum=0\\n                continue\\n            finalsum+=sum\\n        return finalsum\\n\\n","compare_result":"111111111111110000","title_slug":"four-divisors","has_notes":false,"flag_type":1,"frontend_id":293},{"id":1872175063,"question_id":1001,"lang":"python3","lang_name":"Python3","time":"5\xc2\xa0months, 3\xc2\xa0weeks","timestamp":1767367137,"status":10,"status_display":"Accepted","runtime":"0 ms",